    <jobString>Forging vesper halo helm.</jobString>
    <workAmount>2200</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <researchPrerequisite>ABY_CrownCondensationArrays</researchPrerequisite>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>18</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
