<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <RecipeDef>
    <defName>ABY_CraftSaintAegisCarapace</defName>
    <label>forge saint aegis carapace</label>
    <description>Rebuilds a wearable torso shell from a saint reactor core, scorched saint plating and refined abyssal materials. This is not just improved infernal armor; it is salvaged boss shell re-authored for a human frame.</description>
    <jobString>Forging saint aegis carapace.</jobString>
    <workAmount>5800</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <researchPrerequisite>ABY_CrownCondensationArrays</researchPrerequisite>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_ReactorSaintCore</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>34</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>92</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Uranium</li>
          </thingDefs>
        </filter>
        <count>30</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>4</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Gold</li>
          </thingDefs>
        </filter>
        <count>12</count>
      </li>
    </ingredients>
    <products>
      <ABY_SaintAegisCarapace>1</ABY_SaintAegisCarapace>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>600</requiredResidue>
        <category>Armor</category>
      </li>
    </modExtensions>
  </RecipeDef>

  <RecipeDef>
    <defName>ABY_CraftVesperHaloHelm</defName>
