<Defs>

  <RecipeDef>
    <defName>ABY_CraftAshboundTreadBoots</defName>
    <label>forge ashbound tread boots</label>
    <description>Assemble early abyssal tread boots from steel sole plates, residue shock pads and crude ember stabilizers.</description>
    <jobString>Forging ashbound tread boots.</jobString>
    <workAmount>950</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>6</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>24</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <products>
      <ABY_AshboundTreadBoots>1</ABY_AshboundTreadBoots>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>50</requiredResidue>
        <category>Armor</category>
      </li>
    </modExtensions>
  </RecipeDef>

