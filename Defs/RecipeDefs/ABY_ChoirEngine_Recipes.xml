<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <RecipeDef>
    <defName>ABY_CraftChoirEngineSigil</defName>
    <label>forge choir engine sigil</label>
    <description>Builds a command-grade breach sigil from residue, components, and one recovered herald core fragment. This is a post-first-boss escalation step: a hostile support mini-boss that follows the archon kill, amplifies escorts, suppresses turrets, and punishes static defenses.</description>
    <jobString>Forging choir engine sigil.</jobString>
    <workAmount>2550</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_HeraldCoreFragment</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>32</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>3</count>
      </li>
    </ingredients>
    <products>
      <ABY_ChoirEngineSigil>1</ABY_ChoirEngineSigil>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>90</requiredResidue>
        <category>Ritual</category>
      </li>
    </modExtensions>
  </RecipeDef>

</Defs>
