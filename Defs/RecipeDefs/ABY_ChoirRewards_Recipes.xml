  <RecipeDef ParentName="SurgeryInstallImplantBase">
    <defName>ABY_InstallCanticleSubcoreNode</defName>
    <label>install canticle subcore node</label>
    <description>Install a canticle subcore node.</description>
    <descriptionHyperlinks>
      <ThingDef>ABY_CanticleSubcoreNode</ThingDef>
      <HediffDef>ABY_CanticleSubcoreNode_Implant</HediffDef>
    </descriptionHyperlinks>
    <jobString>Installing canticle subcore node.</jobString>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Medicine</li>
          </categories>
        </filter>
        <count>2</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_CanticleSubcoreNode</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <appliedOnFixedBodyParts>
      <li>Brain</li>
    </appliedOnFixedBodyParts>
    <addsHediff>ABY_CanticleSubcoreNode_Implant</addsHediff>
    <recipeUsers Inherit="False">
      <li>Human</li>
      <li MayRequire="Ludeon.RimWorld.Anomaly">CreepJoiner</li>
    </recipeUsers>
  </RecipeDef>

