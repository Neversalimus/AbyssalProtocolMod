<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Surgical installation -->

  <RecipeDef>
    <defName>ABY_InstallAshenLiverLattice</defName>
    <label>install ashen liver lattice</label>
    <description>Install an ashen liver lattice.</description>
    <workerClass>Recipe_InstallImplant</workerClass>
    <jobString>Installing ashen liver lattice.</jobString>
    <anesthetize>true</anesthetize>
    <targetsBodyPart>true</targetsBodyPart>
    <surgerySuccessChanceFactor>1.0</surgerySuccessChanceFactor>
    <ingredients>
      <li>
        <filter><thingDefs><li>MedicineIndustrial</li></thingDefs></filter>
        <count>2</count>
      </li>
      <li>
        <filter><thingDefs><li>ABY_AshenLiverLattice</li></thingDefs></filter>
        <count>1</count>
      </li>
    </ingredients>
    <appliedOnFixedBodyParts>
      <li>Liver</li>
    </appliedOnFixedBodyParts>
    <addsHediff>ABY_AshenLiverLattice_Implant</addsHediff>
    <recipeUsers>
      <li>Human</li>
      <li MayRequire="Ludeon.RimWorld.Anomaly">CreepJoiner</li>
    </recipeUsers>
  </RecipeDef>

