<Defs>

  <!-- Forge crafting -->

  <RecipeDef>
    <defName>ABY_CraftAshenLiverLattice</defName>
    <label>forge ashen liver lattice</label>
    <description>Shape a disciplined ash core into a hepatic lattice optimized for filtration and immune stability.</description>
    <jobString>Forging ashen liver lattice.</jobString>
    <workAmount>1800</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <unfinishedThingDef>UnfinishedHealthItemBionic</unfinishedThingDef>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter><thingDefs><li>ABY_AshenCore</li></thingDefs></filter>
        <count>1</count>
      </li>
      <li>
        <filter><thingDefs><li>ABY_AbyssalResidue</li></thingDefs></filter>
        <count>6</count>
      </li>
      <li>
        <filter><thingDefs><li>Steel</li></thingDefs></filter>
        <count>18</count>
      </li>
      <li>
        <filter><thingDefs><li>ComponentIndustrial</li></thingDefs></filter>
        <count>2</count>
      </li>
    </ingredients>
    <products>
      <ABY_AshenLiverLattice>1</ABY_AshenLiverLattice>
    </products>
  </RecipeDef>

