<Defs>

  <RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
    <defName>ABY_InstallHeraldEye</defName>
    <label>install herald eye</label>
    <description>Install a herald eye.</description>
    <descriptionHyperlinks>
      <ThingDef>ABY_HeraldEye</ThingDef>
      <HediffDef>ABY_HeraldEye_Implant</HediffDef>
    </descriptionHyperlinks>
    <jobString>Installing herald eye.</jobString>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Medicine</li>
          </categories>
        </filter>
        <count>2</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_HeraldEye</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <appliedOnFixedBodyParts>
      <li>Eye</li>
    </appliedOnFixedBodyParts>
    <addsHediff>ABY_HeraldEye_Implant</addsHediff>
    <recipeUsers Inherit="False">
      <li>Human</li>
      <li MayRequire="Ludeon.RimWorld.Anomaly">CreepJoiner</li>
    </recipeUsers>
  </RecipeDef>

