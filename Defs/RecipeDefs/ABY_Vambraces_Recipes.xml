<Defs>

  <RecipeDef>
    <defName>ABY_CraftAshenVambraces</defName>
    <label>forge ashen vambraces</label>
    <description>Assemble early abyssal forearm braces from dark steel plates, residue-lined hinge bands and crude ember conduits.</description>
    <jobString>Forging ashen vambraces.</jobString>
    <workAmount>1050</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>6</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>28</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <products>
      <ABY_AshenVambraces>1</ABY_AshenVambraces>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>50</requiredResidue>
        <category>Armor</category>
      </li>
    </modExtensions>
  </RecipeDef>

