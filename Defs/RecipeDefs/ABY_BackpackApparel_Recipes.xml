<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <RecipeDef>
    <defName>ABY_CraftAshboundFieldPack</defName>
    <label>forge ashbound field pack</label>
    <description>Assemble a crude abyssal field pack from steel, industrial components and a small residue charge. The result is a low-tier harness for carrying more breach gear without committing to a full armor frame.</description>
    <jobString>Forging ashbound field pack.</jobString>
    <workAmount>1300</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>8</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>35</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <products>
      <ABY_AshboundFieldPack>1</ABY_AshboundFieldPack>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>100</requiredResidue>
        <category>Armor</category>
      </li>
    </modExtensions>
  </RecipeDef>

  <RecipeDef>
    <defName>ABY_CraftRiftRelayPack</defName>
    <label>forge rift relay pack</label>
    <description>Bind plasteel plates, advanced components and a stabilized residue channel into a rift relay pack. The pattern is stronger and more mobile than the ashbound field pack, but the carrier remains exposed to a faint psychic resonance.</description>
    <jobString>Forging rift relay pack.</jobString>
    <workAmount>2600</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>22</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>55</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>4</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <products>
      <ABY_RiftRelayPack>1</ABY_RiftRelayPack>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>500</requiredResidue>
        <category>Armor</category>
      </li>
    </modExtensions>
  </RecipeDef>

  <RecipeDef>
    <defName>ABY_CraftCrownConduitPack</defName>
    <label>forge crown conduit pack</label>
    <description>Install a crowned core fragment into a sealed back-mounted conduit frame. This is a late armor-support pattern for operators who need to carry dominion-grade equipment without being slowed to a crawl.</description>
    <jobString>Forging crown conduit pack.</jobString>
    <workAmount>5200</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <researchPrerequisite>ABY_DominionGateBootstrapping</researchPrerequisite>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_CrownedCoreFragment</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>44</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>90</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Uranium</li>
          </thingDefs>
        </filter>
        <count>18</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>4</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Gold</li>
          </thingDefs>
        </filter>
        <count>10</count>
      </li>
    </ingredients>
    <products>
      <ABY_CrownConduitPack>1</ABY_CrownConduitPack>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>2500</requiredResidue>
        <category>Armor</category>
      </li>
    </modExtensions>
  </RecipeDef>

</Defs>
