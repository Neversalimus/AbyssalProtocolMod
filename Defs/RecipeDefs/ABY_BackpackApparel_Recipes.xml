<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <RecipeDef>
    <defName>ABY_CraftAshboundFieldPack</defName>
    <label>forge ashbound field pack</label>
    <description>Assemble a compact field pack from steel bracing, residue canisters and a restrained harness frame.</description>
    <jobString>Forging ashbound field pack.</jobString>
    <workAmount>1400</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter><thingDefs><li>ABY_AbyssalResidue</li></thingDefs></filter>
        <count>8</count>
      </li>
      <li>
        <filter><thingDefs><li>Steel</li></thingDefs></filter>
        <count>35</count>
      </li>
      <li>
        <filter><thingDefs><li>ComponentIndustrial</li></thingDefs></filter>
        <count>2</count>
      </li>
    </ingredients>
    <products>
      <ABY_AshboundFieldPack>1</ABY_AshboundFieldPack>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>50</requiredResidue>
        <category>Armor</category>
      </li>
    </modExtensions>
  </RecipeDef>

