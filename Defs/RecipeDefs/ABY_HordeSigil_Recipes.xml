<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <RecipeDef>
    <defName>ABY_CraftHordeSigil</defName>
    <label>forge horde gate sigil</label>
    <description>Compresses a saint reactor core, residue, plasteel and spacer hardware into a post-saint horde-routing sigil. Instead of calling a named boss, this invocation tears open multiple perimeter breaches and floods the map with ordinary abyssal warforms. It is the first deliberate army-scale ritual after Reactor Saint.</description>
    <jobString>Forging horde gate sigil.</jobString>
    <workAmount>3900</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_ReactorSaintCore</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>44</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>64</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>4</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>3</count>
      </li>
    </ingredients>
    <products>
      <ABY_HordeSigil>1</ABY_HordeSigil>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>135</requiredResidue>
        <category>Ritual</category>
      </li>
    </modExtensions>
  </RecipeDef>

</Defs>
