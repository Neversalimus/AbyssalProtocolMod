<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <RecipeDef>
    <defName>ABY_CraftAshboundCapacitorModule</defName>
    <label>forge ashbound capacitor module</label>
    <description>Compress residue, alloy and industrial clamps into the first abyssal charge-buffer module for the summoning circle.</description>
    <jobString>Forging ashbound capacitor module.</jobString>
    <workAmount>1800</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <researchPrerequisite>ABY_AshboundCapacitance</researchPrerequisite>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>12</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>45</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <products>
      <ABY_AshboundCapacitorModule>1</ABY_AshboundCapacitorModule>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>35</requiredResidue>
        <category>Core</category>
      </li>
    </modExtensions>
  </RecipeDef>

