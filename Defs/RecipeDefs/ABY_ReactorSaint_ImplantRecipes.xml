  <RecipeDef ParentName="SurgeryInstallBodyPartProstheticBase">
    <defName>ABY_InstallSaintReactorHeart</defName>
    <label>install saint reactor heart</label>
    <description>Install a saint reactor heart.</description>
    <descriptionHyperlinks>
      <ThingDef>ABY_SaintReactorHeart</ThingDef>
      <HediffDef>ABY_SaintReactorHeart_Implant</HediffDef>
    </descriptionHyperlinks>
    <jobString>Installing saint reactor heart.</jobString>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Medicine</li>
          </categories>
        </filter>
        <count>2</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_SaintReactorHeart</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <appliedOnFixedBodyParts>
      <li>Heart</li>
    </appliedOnFixedBodyParts>
    <addsHediff>ABY_SaintReactorHeart_Implant</addsHediff>
    <recipeUsers Inherit="False">
      <li>Human</li>
      <li MayRequire="Ludeon.RimWorld.Anomaly">CreepJoiner</li>
    </recipeUsers>
  </RecipeDef>

