    <addsHediff>ABY_CohortSyncSubnode_Implant</addsHediff>
    <recipeUsers Inherit="False">
      <li>Human</li>
      <li MayRequire="Ludeon.RimWorld.Anomaly">CreepJoiner</li>
    </recipeUsers>
  </RecipeDef>

