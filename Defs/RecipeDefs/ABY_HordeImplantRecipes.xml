      <ThingDef>ABY_CohortSyncSubnode</ThingDef>
      <HediffDef>ABY_CohortSyncSubnode_Implant</HediffDef>
    </descriptionHyperlinks>
    <jobString>Installing cohort sync subnode.</jobString>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>Medicine</li>
          </categories>
        </filter>
        <count>2</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_CohortSyncSubnode</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
