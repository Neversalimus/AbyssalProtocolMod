  <RecipeDef>
    <defName>ABY_CraftCrownStabilizerModule</defName>
    <label>forge crown stabilizer module</label>
    <description>Fabricate a crown-tier restraint engine for high-threat ritual work. These are intended for circles that are expected to survive serious breach pressure instead of merely limping through it.</description>
