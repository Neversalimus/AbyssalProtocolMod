<?xml version='1.0' encoding='utf-8'?>
<Defs>
  <RecipeDef>
    <defName>ABY_CraftResidue</defName>
    <label>condense abyssal residue</label>
    <description>Industrial ritual process that converts metal and components into inert abyssal residue.</description>
    <jobString>Condensing abyssal residue.</jobString>
    <workAmount>900</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>40</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
    </ingredients>
    <products>
      <ABY_AbyssalResidue>12</ABY_AbyssalResidue>
    </products>
  </RecipeDef>
  <RecipeDef>
    <defName>ABY_CraftResiduePlasteelSpacer</defName>
    <label>condense reinforced abyssal residue</label>
    <description>High-pressure forge communion that converts plasteel and advanced components into a denser yield of inert abyssal residue.</description>
    <jobString>Condensing reinforced abyssal residue.</jobString>
    <workAmount>1700</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>25</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <products>
      <ABY_AbyssalResidue>42</ABY_AbyssalResidue>
    </products>
  </RecipeDef>
  <RecipeDef>
    <defName>ABY_CraftResiduePreciousMetals</defName>
    <label>condense gilded abyssal residue</label>
    <description>Ritualized precious-metal compression that converts gold and silver into a refined cache of inert abyssal residue.</description>
    <jobString>Condensing gilded abyssal residue.</jobString>
    <workAmount>1450</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Gold</li>
          </thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Silver</li>
          </thingDefs>
        </filter>
        <count>120</count>
      </li>
    </ingredients>
    <products>
      <ABY_AbyssalResidue>30</ABY_AbyssalResidue>
    </products>
  </RecipeDef>
  <RecipeDef>
    <defName>ABY_CraftArchonSigil</defName>
    <label>forge archon sigil</label>
    <description>Compress residue into a stable breach-key used to summon the first boss.</description>
    <jobString>Forging archon sigil.</jobString>
    <workAmount>1600</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>18</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>25</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <products>
      <ABY_ArchonSigil>1</ABY_ArchonSigil>
    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <category>Ritual</category>
      </li>
    </modExtensions>
  </RecipeDef>
</Defs>