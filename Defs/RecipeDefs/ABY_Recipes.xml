    </products>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>10</requiredResidue>
        <category>Ritual</category>
      </li>
    </modExtensions>
  </RecipeDef>

