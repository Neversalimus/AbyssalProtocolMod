<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <RecipeDef>
    <defName>ABY_CraftResidue</defName>
    <label>condense abyssal residue</label>
    <description>Industrial ritual process that converts metal and components into inert abyssal residue. This is the first material step of the summon loop and the foundation for sigils and early herald fabrication.</description>
    <jobString>Condensing abyssal residue.</jobString>
    <workAmount>1000</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <researchPrerequisite>ABY_AbyssalSignalTheory</researchPrerequisite>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>80</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <products>
      <ABY_AbyssalResidue>10</ABY_AbyssalResidue>
    </products>
  </RecipeDef>

  <RecipeDef>
    <defName>ABY_CraftArchonSigil</defName>
    <label>forge archon sigil</label>
    <description>Compress residue into a stable breach-key used to summon the first boss. Use the finished sigil at a powered Abyssal Summoning Circle with a clear ritual focus.</description>
    <jobString>Forging archon sigil.</jobString>
    <workAmount>2200</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <researchPrerequisite>ABY_AbyssalSignalTheory</researchPrerequisite>
    <recipeUsers>
      <li>ABY_AbyssalForge</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>ABY_AbyssalResidue</li>
          </thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>30</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
    </ingredients>
    <products>
      <ABY_ArchonSigil>1</ABY_ArchonSigil>
    </products>
  </RecipeDef>

</Defs>
