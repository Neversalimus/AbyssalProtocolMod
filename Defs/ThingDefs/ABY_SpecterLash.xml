<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_SpecterLashProjector</defName>
    <label>specter lash projector</label>
    <description>A residue-fed tether projector that snaps an impact point into a writhing containment lash. On a solid hit the stream clings to the victim, weaving from side to side and burning through the target in repeated pulses instead of a single straight beam.</description>
    <techLevel>Spacer</techLevel>

    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/ABY_SpecterLashProjector</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.36,0.46)</drawSize>
    </graphicData>

    <soundInteract>Interact_ChargeRifle</soundInteract>

    <statBases>
      <WorkToMake>48000</WorkToMake>
      <Mass>4.7</Mass>
      <MarketValue>2650</MarketValue>
      <AccuracyTouch>0.83</AccuracyTouch>
      <AccuracyShort>0.77</AccuracyShort>
      <AccuracyMedium>0.67</AccuracyMedium>
      <AccuracyLong>0.52</AccuracyLong>
      <RangedWeapon_Cooldown>2.50</RangedWeapon_Cooldown>
    </statBases>

    <recipeMaker>
      <skillRequirements>
        <Crafting>10</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
    </recipeMaker>

    <costList>
      <ABY_AbyssalResidue>24</ABY_AbyssalResidue>
      <Plasteel>65</Plasteel>
      <Steel>80</Steel>
      <ComponentSpacer>4</ComponentSpacer>
    </costList>

    <weaponTags>
      <li>SpacerGun</li>
      <li>RangedHeavy</li>
    </weaponTags>

    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_SpecterLashAnchor</defaultProjectile>
        <warmupTime>1.25</warmupTime>
        <range>26.9</range>
        <ticksBetweenBurstShots>1</ticksBetweenBurstShots>
        <burstShotCount>1</burstShotCount>
        <soundAiming>ABY_SpecterLashCharge</soundAiming>
        <soundCast>ABY_SpecterLashFire</soundCast>
        <soundCastTail>ABY_SpecterLashTail</soundCastTail>
        <muzzleFlashScale>12.4</muzzleFlashScale>
      </li>
    </verbs>

    <tools>
      <li>
        <label>housing</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>10</power>
        <cooldownTime>2.1</cooldownTime>
      </li>
    </tools>

    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>450</requiredResidue>
        <category>Weapons</category>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_SpecterLashAnchor</defName>
    <label>specter lash anchor</label>
    <thingClass>AbyssalProtocol.Projectile_SpecterLashAnchor</thingClass>
    <graphicData>
      <texPath>Things/Projectile/ABY_SpecterLashAnchor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.14,0.26)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Burn</damageDef>
      <damageAmountBase>26</damageAmountBase>
      <armorPenetrationBase>0.90</armorPenetrationBase>
      <stoppingPower>0.45</stoppingPower>
      <speed>120</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>

</Defs>
