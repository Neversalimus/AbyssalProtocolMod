<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseMeleeWeapon_Sharp_Quality">
    <defName>ABY_NullbrandGlaive</defName>
    <label>nullbrand glaive</label>
    <description>A stabilized abyssal poleblade built around a compressed null-core. Repeated strikes fracture the target's surface integrity, then shear through the open fault before armor, chitin or machine plating can remember its shape.</description>
    <techLevel>Spacer</techLevel>

    <graphicData>
      <texPath>Things/Weapon/ABY_NullbrandGlaive</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.36,1.36)</drawSize>
    </graphicData>

    <recipeMaker>
      <skillRequirements>
        <Crafting>9</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
    </recipeMaker>

    <costList>
      <ABY_AshenCore>1</ABY_AshenCore>
      <ABY_AbyssalResidue>24</ABY_AbyssalResidue>
      <Plasteel>75</Plasteel>
      <Steel>35</Steel>
      <ComponentSpacer>3</ComponentSpacer>
    </costList>

    <tools>
      <li>
        <label>nullbrand cleave</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>33</power>
        <cooldownTime>1.82</cooldownTime>
        <armorPenetration>0.54</armorPenetration>
        <extraMeleeDamages>
          <li>
            <def>ABY_NullbrandFractureDamage</def>
            <amount>1</amount>
            <armorPenetration>0</armorPenetration>
          </li>
        </extraMeleeDamages>
      </li>
      <li>
        <label>hooking spike</label>
        <capacities>
          <li>Poke</li>
        </capacities>
        <power>24</power>
        <cooldownTime>1.62</cooldownTime>
        <armorPenetration>0.66</armorPenetration>
        <extraMeleeDamages>
          <li>
            <def>ABY_NullbrandFractureDamage</def>
            <amount>1</amount>
            <armorPenetration>0</armorPenetration>
          </li>
        </extraMeleeDamages>
      </li>
      <li>
        <label>weighted haft</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>15</power>
        <cooldownTime>1.75</cooldownTime>
        <armorPenetration>0.18</armorPenetration>
      </li>
    </tools>

    <statBases>
      <WorkToMake>56000</WorkToMake>
      <Mass>3.9</Mass>
      <MarketValue>3020</MarketValue>
    </statBases>

    <comps>
      <li Class="AbyssalProtocol.CompProperties_ABY_WeaponGlowOverlay">
        <texPath>Things/Weapon/ABY_NullbrandGlaive_Glow</texPath>
        <drawSizeX>1.36</drawSizeX>
        <drawSizeZ>1.36</drawSizeZ>
        <alpha>0.62</alpha>
      </li>
    </comps>

    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>450</requiredResidue>
        <category>Weapons</category>
      </li>
    </modExtensions>
  </ThingDef>

</Defs>
