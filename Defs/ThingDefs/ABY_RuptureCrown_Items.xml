<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="ApparelBase">
    <defName>ABY_CrownOfRupture</defName>
    <thingClass>Apparel</thingClass>
    <label>crown of rupture</label>
    <description>A collapsed crown-reactor torn from the hidden archon. It stores a single verdict charge and can be worn alongside normal weapons. Once discharged, it condenses a new charge over one full in-game day while projecting a living infernal halo above the wearer.</description>
    <techLevel>Ultra</techLevel>
    <graphicData>
      <texPath>Things/Item/ABY_CrownOfRupture</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.62,0.62)</drawSize>
    </graphicData>
    <apparel>
      <bodyPartGroups>
        <li>Waist</li>
      </bodyPartGroups>
      <layers>
        <li>Belt</li>
      </layers>
      <wornGraphicPath>Apparel/ABY_CrownOfRupture_Worn</wornGraphicPath>
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
    </apparel>
    <tradeability>Sellable</tradeability>
    <soundInteract>Interact_ChargeRifle</soundInteract>
    <smeltable>false</smeltable>
    <equippedStatOffsets>
      <MoveSpeed>0.08</MoveSpeed>
      <ShootingAccuracyPawn>0.08</ShootingAccuracyPawn>
      <MeleeDodgeChance>0.10</MeleeDodgeChance>
    </equippedStatOffsets>
    <statBases>
      <WorkToMake>50000</WorkToMake>
      <MaxHitPoints>220</MaxHitPoints>
      <Mass>1.2</Mass>
      <MarketValue>6800</MarketValue>
      <ArmorRating_Sharp>0.08</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.12</ArmorRating_Blunt>
      <ArmorRating_Heat>0.20</ArmorRating_Heat>
    </statBases>
    <comps>
      <li Class="AbyssalProtocol.CompProperties_RuptureCrown">
        <rechargeTicks>60000</rechargeTicks>
        <sentenceRange>35.9</sentenceRange>
      </li>
    </comps>
  </ThingDef>

</Defs>
