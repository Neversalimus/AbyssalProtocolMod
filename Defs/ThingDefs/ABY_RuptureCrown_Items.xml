<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_CrownOfRupture</defName>
    <label>crown of rupture</label>
    <description>A collapsed crown-reactor torn from the hidden archon. It stores a single verdict charge. Once fired, it condenses a new charge over one full in-game day without locking the wielder in place. While equipped it sharpens motion, aim and evasive timing, and projects a living infernal halo above the wearer.</description>
    <techLevel>Ultra</techLevel>
    <thingCategories Inherit="False">
      <li>WeaponsRanged</li>
    </thingCategories>
    <graphicData>
      <texPath>Things/Item/ABY_CrownOfRupture</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <tradeability>Sellable</tradeability>
    <soundInteract>Interact_ChargeRifle</soundInteract>
    <smeltable>false</smeltable>
    <recipeMaker Inherit="False" />
    <costList>
      <Steel>1</Steel>
    </costList>
    <weaponTags>
      <li>SpacerGun</li>
      <li>Gun</li>
      <li>RangedHeavy</li>
    </weaponTags>
    <equippedStatOffsets>
      <MoveSpeed>0.08</MoveSpeed>
      <ShootingAccuracyPawn>0.08</ShootingAccuracyPawn>
      <MeleeDodgeChance>0.10</MeleeDodgeChance>
    </equippedStatOffsets>
    <statBases>
      <WorkToMake>50000</WorkToMake>
      <Mass>1.7</Mass>
      <MarketValue>6800</MarketValue>
      <AccuracyTouch>0.95</AccuracyTouch>
      <AccuracyShort>0.92</AccuracyShort>
      <AccuracyMedium>0.88</AccuracyMedium>
      <AccuracyLong>0.84</AccuracyLong>
      <RangedWeapon_Cooldown>1.80</RangedWeapon_Cooldown>
    </statBases>
    <verbs>
      <li>
        <verbClass>AbyssalProtocol.Verb_RuptureSentence</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_RuptureSentenceBolt</defaultProjectile>
        <warmupTime>1.30</warmupTime>
        <range>35.9</range>
        <burstShotCount>1</burstShotCount>
        <ticksBetweenBurstShots>1</ticksBetweenBurstShots>
        <soundCast>ABY_RuptureVerdict</soundCast>
        <muzzleFlashScale>1.25</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>crown edge</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>10</power>
        <cooldownTime>2.2</cooldownTime>
      </li>
    </tools>
    <comps>
      <li Class="AbyssalProtocol.CompProperties_RuptureCrown">
        <rechargeTicks>60000</rechargeTicks>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_RuptureSentenceBolt</defName>
    <label>rupture sentence bolt</label>
    <thingClass>AbyssalProtocol.Projectile_RuptureSentence</thingClass>
    <graphicData>
      <texPath>Things/Projectile/UltraPlasmaBolt</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.30,1.30)</drawSize>
      <color>(255,70,70)</color>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>0</damageAmountBase>
      <armorPenetrationBase>0</armorPenetrationBase>
      <stoppingPower>0.05</stoppingPower>
      <speed>90</speed>
      <soundImpactAnticipate>ABY_RuptureImpact</soundImpactAnticipate>
    </projectile>
  </ThingDef>

</Defs>
