<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_HeraldCoreFragment</defName>
    <label>herald core fragment</label>
    <description>A jagged vertebral reactor-shard carved out of the first boss. It still pulses with chained archon routines and is stable enough to anchor only one high-grade infernal implant project per kill.</description>
    <graphicData>
      <texPath>Things/Item/ABY_HeraldCoreFragment</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <color>(255,102,72)</color>
    </graphicData>
    <tradeability>Sellable</tradeability>
    <stackLimit>10</stackLimit>
    <statBases>
      <MarketValue>380</MarketValue>
      <Mass>0.18</Mass>
      <Flammability>0</Flammability>
    </statBases>
  </ThingDef>

  <ThingDef ParentName="BodyPartBionicBase">
    <defName>ABY_HeraldEye</defName>
    <label>herald eye</label>
    <description>A boss-grade infernal ocular implant assembled around a stabilized herald fragment. It pushes aiming noticeably beyond standard bionics, but stops short of true archotech territory.</description>
    <graphicData>
      <texPath>Things/Implant/ABY_HeraldEye</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>1</stackLimit>
    <tradeability>Sellable</tradeability>
    <techLevel>Spacer</techLevel>
    <statBases>
      <Mass>0.16</Mass>
      <WorkToMake>30000</WorkToMake>
      <MarketValue>1450</MarketValue>
      <Flammability>0</Flammability>
    </statBases>
    <recipeMaker>
      <researchPrerequisite>ABY_HeraldImplantIntegration</researchPrerequisite>
      <skillRequirements>
        <Crafting>10</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
      <unfinishedThingDef>UnfinishedHealthItemBionic</unfinishedThingDef>
    </recipeMaker>
    <costList>
      <ABY_HeraldCoreFragment>2</ABY_HeraldCoreFragment>
      <ABY_AbyssalResidue>12</ABY_AbyssalResidue>
      <ComponentIndustrial>2</ComponentIndustrial>
      <Plasteel>15</Plasteel>
      <Steel>30</Steel>
    </costList>
  </ThingDef>

  <ThingDef ParentName="BodyPartBionicBase">
    <defName>ABY_ArchonTendonSpine</defName>
