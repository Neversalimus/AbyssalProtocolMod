      <ABY_AbyssalResidue>16</ABY_AbyssalResidue>
      <ComponentIndustrial>3</ComponentIndustrial>
      <Plasteel>20</Plasteel>
      <Steel>40</Steel>
    </costList>
  </ThingDef>

  <ThingDef ParentName="BodyPartBionicBase">
    <defName>ABY_HeraldCarapaceMesh</defName>
    <label>herald carapace mesh</label>
    <description>A folded subdermal abyssal mesh plated from herald chitin and infernal alloy. It grants light built-in armor and heat shielding with only a small movement and beauty penalty.</description>
    <graphicData>
