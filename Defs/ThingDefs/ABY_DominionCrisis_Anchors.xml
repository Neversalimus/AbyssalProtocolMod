<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_DominionAnchor_Suppression</defName>
    <label>suppression anchor</label>
    <description>A dominion anchor tuned to suppress defensive response. It periodically lashes nearby turrets with EMP pressure and keeps static fire lanes unreliable while the breach remains active.</description>
    <thingClass>AbyssalProtocol.Building_AbyssalDominionAnchor</thingClass>
    <category>Building</category>
    <drawerType>MapMeshAndRealTime</drawerType>
    <tickerType>Normal</tickerType>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <fillPercent>0.28</fillPercent>
    <rotatable>false</rotatable>
    <selectable>true</selectable>
    <useHitPoints>true</useHitPoints>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <graphicData>
      <texPath>Things/Building/DominionAnchors/ABY_DominionAnchor_Suppression</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(6.6,6.6)</drawSize>
    </graphicData>
    <statBases>
      <MaxHitPoints>560</MaxHitPoints>
      <Mass>60</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <size>(2,2)</size>
    <thingCategories Inherit="False" />
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_DominionAnchor">
        <role>Suppression</role>
        <pulseIntervalTicks>210</pulseIntervalTicks>
        <pulseRadius>12.5</pulseRadius>
        <empDamage>3.2</empDamage>
        <maxAffectedTargets>5</maxAffectedTargets>
        <contaminationPulse>0.010</contaminationPulse>
        <glowTexPath>Things/Building/DominionAnchors/ABY_DominionAnchor_Suppression_Glow</glowTexPath>
        <glowDrawScale>7.26</glowDrawScale>
      </li>
    </modExtensions>
  </ThingDef>

