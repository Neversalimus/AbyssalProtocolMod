<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BenchBase">
    <defName>ABY_AbyssalForge</defName>
    <label>abyssal forge</label>
    <description>A living techno-demonic fabrication altar. The forge distills residue, brands summon sigils, and assembles abyssal weapons and implants around a pulsing infernal reactor-heart. Tool cabinets support this bench, while the circle remains a separate ritual anchor.</description>

    <thingClass>AbyssalProtocol.Building_AbyssalForge</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>

    <graphicData>
      <texPath>Things/Building/ABY_AbyssalForge</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(3.22,1.18)</drawSize>
    </graphicData>

    <castEdgeShadows>false</castEdgeShadows>
    <staticSunShadowHeight>0.03</staticSunShadowHeight>
    <constructEffect>ConstructMetal</constructEffect>

    <costList>
      <Steel>180</Steel>
      <Plasteel>55</Plasteel>
      <ComponentIndustrial>4</ComponentIndustrial>
      <ComponentSpacer>2</ComponentSpacer>
    </costList>

    <altitudeLayer>Building</altitudeLayer>
    <fillPercent>0.18</fillPercent>
    <useHitPoints>True</useHitPoints>

    <statBases>
      <WorkToBuild>7200</WorkToBuild>
      <MaxHitPoints>320</MaxHitPoints>
      <Flammability>0.08</Flammability>
      <Cleanliness>-1.5</Cleanliness>
    </statBases>

    <size>(3,1)</size>
    <designationCategory>Production</designationCategory>
    <uiOrder>2521</uiOrder>
    <passability>PassThroughOnly</passability>
    <pathCost>28</pathCost>
    <hasInteractionCell>True</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <surfaceType>Item</surfaceType>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <minifiedDef IsNull="True" />

    <inspectorTabs>
      <li>ITab_Bills</li>
    </inspectorTabs>

    <comps Inherit="False">
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <shortCircuitInRain>true</shortCircuitInRain>
        <basePowerConsumption>950</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable" />
      <li Class="CompProperties_Glower">
        <glowRadius>4.1</glowRadius>
        <glowColor>(255,92,38,0)</glowColor>
      </li>
      <li Class="CompProperties_AffectedByFacilities">
        <linkableFacilities>
          <li>ToolCabinet</li>
        </linkableFacilities>
      </li>
      <li Class="CompProperties_Breakdownable" />
    </comps>

    <building>
      <spawnedConceptLearnOpportunity>BillsTab</spawnedConceptLearnOpportunity>
      <workTableRoomRole>Workshop</workTableRoomRole>
      <workTableNotInRoomRoleFactor>0.8</workTableNotInRoomRoleFactor>
    </building>

    <researchPrerequisites>
      <li>ABY_AbyssalSignalTheory</li>
    </researchPrerequisites>

    <placeWorkers>
      <li>PlaceWorker_ShowFacilitiesConnections</li>
      <li>PlaceWorker_PreventInteractionSpotOverlap</li>
    </placeWorkers>
  </ThingDef>

</Defs>
