  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_CanticleDriver</defName>
    <label>canticle driver</label>
    <description>A choir-pattern sonic pressure rifle that launches compact resonance spikes rather than hot plasma. It is built to stagger flesh, punish exposed infantry and break firing rhythm through blunt pressure and hostile sound, not to serve as a pure anti-armor lance.</description>
    <graphicData>
      <texPath>Things/Weapon/ABY_CanticleDriver</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.36,0.48)</drawSize>
    </graphicData>
    <soundInteract>Interact_ChargeRifle</soundInteract>
    <techLevel>Spacer</techLevel>
    <weaponTags>
      <li>Gun</li>
      <li>RangedHeavy</li>
    </weaponTags>
    <recipeMaker>
      <skillRequirements>
        <Crafting>11</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
    </recipeMaker>
    <costList>
      <ABY_ChoirResonanceCore>1</ABY_ChoirResonanceCore>
      <ABY_AbyssalResidue>18</ABY_AbyssalResidue>
      <Plasteel>38</Plasteel>
      <Steel>46</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
      <Gold>6</Gold>
    </costList>
    <statBases>
      <WorkToMake>48000</WorkToMake>
      <Mass>4.8</Mass>
      <MarketValue>2280</MarketValue>
      <AccuracyTouch>0.78</AccuracyTouch>
      <AccuracyShort>0.84</AccuracyShort>
      <AccuracyMedium>0.80</AccuracyMedium>
      <AccuracyLong>0.64</AccuracyLong>
      <RangedWeapon_Cooldown>2.20</RangedWeapon_Cooldown>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_CanticleWaveProjectile</defaultProjectile>
        <warmupTime>1.40</warmupTime>
        <range>30.9</range>
        <burstShotCount>2</burstShotCount>
        <ticksBetweenBurstShots>8</ticksBetweenBurstShots>
        <soundAiming>ABY_CanticleDriverAim</soundAiming>
        <soundCast>ABY_CanticleDriverFire</soundCast>
        <soundCastTail>ABY_CanticleDriverTail</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>400</requiredResidue>
        <category>Weapons</category>
      </li>
