<Defs>
  <ThingDef ParentName="ResourceBase">
    <defName>ABY_ChoirResonanceCore</defName>
    <label>choir resonance core</label>
    <description>A disciplined choir-core prism recovered from the relay engine. Unlike the jagged herald fragment, this node is built for coherence: pressure, timing, signal shaping, and hostile command rhythm held inside a stable resonant shell.</description>
    <graphicData>
      <texPath>Things/Item/ABY_ChoirResonanceCore</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>10</stackLimit>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <statBases>
      <MarketValue>330</MarketValue>
      <Mass>0.18</Mass>
      <Flammability>0</Flammability>
    </statBases>
  </ThingDef>
