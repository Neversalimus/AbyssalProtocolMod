<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BasePawn">
    <defName>ABY_WardenOfAsh</defName>
    <label>warden of ash</label>
    <description>An infernal techno-warden built as the first disciplined overseer of abyssal breach pressure. Its armor is ash-black and furnace-heavy, with a contained portal embedded in the chest to mark it as both executioner and living gate-node.</description>

    <thingClass>Pawn</thingClass>
    <deathActionWorkerClass>AbyssalProtocol.DeathActionWorker_DropAshenCore</deathActionWorkerClass>
    <tickerType>Normal</tickerType>
    <selectable>true</selectable>
    <useHitPoints>true</useHitPoints>

    <graphicData>
      <texPath>Pawn/WardenOfAsh/WardenOfAsh</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(3.20,3.20)</drawSize>
    </graphicData>

    <race>
      <body>Human</body>
      <baseBodySize>1.45</baseBodySize>
      <baseHealthScale>2.25</baseHealthScale>
      <lifeStageAges>
        <li>
          <def>HumanlikeAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
      <intelligence>Humanlike</intelligence>
      <foodType>OmnivoreHuman</foodType>
      <thinkTreeMain>Humanlike</thinkTreeMain>
      <thinkTreeConstant>HumanlikeConstant</thinkTreeConstant>
      <fleshType>Normal</fleshType>
      <hasGenders>false</hasGenders>
      <bloodDef>Blood</bloodDef>
      <meatLabel>ash-charred flesh</meatLabel>
      <corpseLabel>warden husk</corpseLabel>
      <soundMeleeHitPawn>Pawn_Melee_Punch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_Punch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_Punch_Miss</soundMeleeMiss>
      <herdMigrationAllowed>false</herdMigrationAllowed>
      <predator>false</predator>
      <wildness>0</wildness>
      <trainability>None</trainability>
    </race>

    <statBases>
      <MaxHitPoints>1180</MaxHitPoints>
      <MoveSpeed>4.20</MoveSpeed>
      <MeleeHitChance>0.92</MeleeHitChance>
      <MeleeDodgeChance>0.18</MeleeDodgeChance>
      <ArmorRating_Sharp>0.66</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.48</ArmorRating_Blunt>
      <ArmorRating_Heat>1.45</ArmorRating_Heat>
      <ComfyTemperatureMin>-20</ComfyTemperatureMin>
      <ComfyTemperatureMax>240</ComfyTemperatureMax>
      <Mass>1.50</Mass>
      <MarketValue>1250</MarketValue>
      <Flammability>0.00</Flammability>
    </statBases>

    <tools>
      <li>
        <label>ash pike</label>
        <capacities>
          <li>Stab</li>
          <li>Blunt</li>
        </capacities>
        <power>28</power>
        <cooldownTime>1.75</cooldownTime>
        <chanceFactor>1.05</chanceFactor>
        <armorPenetration>0.28</armorPenetration>
      </li>
      <li>
        <label>censer smash</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>20</power>
        <cooldownTime>2.25</cooldownTime>
        <chanceFactor>0.82</chanceFactor>
        <armorPenetration>0.19</armorPenetration>
      </li>
    </tools>

    <comps>
      <li Class="AbyssalProtocol.CompProperties_ABY_WardenOfAshPulse">
        <warmupTicks>210</warmupTicks>
        <pulseIntervalTicks>345</pulseIntervalTicks>
        <pulseIntervalVariance>60</pulseIntervalVariance>
        <pulseRadius>3.7</pulseRadius>
        <pulseDamage>15</pulseDamage>
        <pulseArmorPenetration>0.18</pulseArmorPenetration>
        <igniteChancePerCell>0.13</igniteChancePerCell>
        <maxCellsToIgnite>4</maxCellsToIgnite>
        <visualScale>1.95</visualScale>
        <pulseSoundDefName>ABY_SigilChargePulse</pulseSoundDefName>
      </li>
      <li Class="AbyssalProtocol.CompProperties_ABY_WardenOfAshPortalSummoner">
        <threshold75Count>3</threshold75Count>
        <threshold40Count>4</threshold40Count>
        <threshold15Count>3</threshold15Count>
        <portalMinRadius>1.35</portalMinRadius>
        <portalMaxRadius>2.75</portalMaxRadius>
        <portalWarmupTicks>24</portalWarmupTicks>
        <portalSpawnIntervalTicks>8</portalSpawnIntervalTicks>
        <portalLingerTicks>105</portalLingerTicks>
        <portalFlashScale>2.3</portalFlashScale>
        <portalSoundDefName>ABY_SigilChargePulse</portalSoundDefName>
      </li>
    </comps>
  </ThingDef>

</Defs>
