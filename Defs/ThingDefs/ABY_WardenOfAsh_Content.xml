    <tools>
      <li>
        <label>ash pike</label>
        <capacities>
          <li>Stab</li>
          <li>Blunt</li>
        </capacities>
        <power>24</power>
        <cooldownTime>1.85</cooldownTime>
        <chanceFactor>1.05</chanceFactor>
        <armorPenetration>0.24</armorPenetration>
      </li>
      <li>
        <label>censer smash</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>18</power>
        <cooldownTime>2.35</cooldownTime>
        <chanceFactor>0.78</chanceFactor>
        <armorPenetration>0.18</armorPenetration>
      </li>
    </tools>
