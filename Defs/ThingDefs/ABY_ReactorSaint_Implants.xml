<Defs>

  <ThingDef ParentName="BodyPartBionicBase">
    <defName>ABY_SaintReactorHeart</defName>
    <label>saint reactor heart</label>
    <description>A reactor-disciplined abyssal heart grown around a saint-class core. It does not simply push blood harder; it enforces a cleaner combat rhythm, steadier consciousness, and a body that can tolerate infernal heat without collapsing into panic or pain shock.</description>
    <graphicData>
      <texPath>Things/Implant/ABY_SaintReactorHeart</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>1</stackLimit>
    <tradeability>Sellable</tradeability>
    <techLevel>Spacer</techLevel>
    <statBases>
      <Mass>0.30</Mass>
      <WorkToMake>42000</WorkToMake>
      <MarketValue>2650</MarketValue>
      <Flammability>0</Flammability>
    </statBases>
    <recipeMaker>
      <skillRequirements>
        <Crafting>12</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
      <unfinishedThingDef>UnfinishedHealthItemBionic</unfinishedThingDef>
    </recipeMaker>
    <costList>
      <ABY_ReactorSaintCore>1</ABY_ReactorSaintCore>
      <ABY_AbyssalResidue>24</ABY_AbyssalResidue>
      <ComponentIndustrial>3</ComponentIndustrial>
      <ComponentSpacer>2</ComponentSpacer>
      <Plasteel>24</Plasteel>
      <Steel>30</Steel>
      <Gold>6</Gold>
    </costList>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>420</requiredResidue>
        <category>Implants</category>
      </li>
    </modExtensions>
  </ThingDef>

