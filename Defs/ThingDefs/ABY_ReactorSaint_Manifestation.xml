<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_Manifestation_ReactorSaintArrivalControlled</defName>
    <label>reactor saint manifestation</label>
    <description>A controlled reactor-saint breach cocoon descending toward the colony through a stabilized manifestation channel.</description>
    <thingClass>AbyssalProtocol.Building_ABY_ReactorSaintManifestation</thingClass>
    <category>Building</category>
    <graphicData>
      <texPath>Things/VFX/Manifestation/ABY_Manifestation_Invisible</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <drawSize>(1.0,1.0)</drawSize>
    </graphicData>
    <tickerType>Normal</tickerType>
    <fillPercent>0.01</fillPercent>
    <passability>PassThroughOnly</passability>
    <selectable>false</selectable>
    <useHitPoints>false</useHitPoints>
    <rotatable>false</rotatable>
    <altitudeLayer>MetaOverlays</altitudeLayer>
    <drawOffscreen>true</drawOffscreen>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_Manifestation_ReactorSaintArrival</defName>
    <label>reactor saint cocoon incoming</label>
    <description>A biomechanical breach cocoon descending toward the colony.</description>
    <thingClass>RimWorld.Skyfaller</thingClass>
    <category>Ethereal</category>
    <tickerType>Normal</tickerType>
    <drawerType>RealtimeOnly</drawerType>
    <drawOffscreen>true</drawOffscreen>
    <useHitPoints>false</useHitPoints>
    <selectable>false</selectable>
    <altitudeLayer>Skyfaller</altitudeLayer>
    <graphicData>
      <texPath>Things/VFX/ReactorSaintArrival/ABY_ReactorSaintCocoon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutFlying</shaderType>
      <drawSize>(15.95,23.10)</drawSize>
    </graphicData>
    <skyfaller>
      <ticksToImpactRange>
        <min>60</min>
        <max>70</max>
      </ticksToImpactRange>
      <movementType>Accelerate</movementType>
      <speed>0.85</speed>
      <shadow>Things/Skyfaller/SkyfallerShadowDropPod</shadow>
      <shadowSize>(23.10,23.10)</shadowSize>
      <cameraShake>0.75</cameraShake>
      <impactSound>ABY_ReactorSaintBarrageImpact</impactSound>
      <anticipationSound>DropPod_Fall</anticipationSound>
      <anticipationSoundTicks>55</anticipationSoundTicks>
      <motesPerCell>0</motesPerCell>
      <spawnThing>ABY_ReactorSaintCocoon</spawnThing>
    </skyfaller>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_ReactorSaintCocoon</defName>
    <label>reactor saint cocoon</label>
    <description>A reactor-sealed cocoon holding the Infernal Reactor Saint in a suspended breach state.</description>
    <thingClass>AbyssalProtocol.Building_ABY_ReactorSaintCocoon</thingClass>
    <category>Building</category>
    <tickerType>Normal</tickerType>
    <drawerType>RealtimeOnly</drawerType>
    <useHitPoints>false</useHitPoints>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.01</fillPercent>
    <selectable>false</selectable>
    <rotatable>false</rotatable>
    <altitudeLayer>BuildingOnTop</altitudeLayer>
    <drawOffscreen>true</drawOffscreen>
    <graphicData>
      <texPath>Things/VFX/ReactorSaintArrival/ABY_ReactorSaintCocoon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>Cutout</shaderType>
      <drawSize>(15.95,23.10)</drawSize>
    </graphicData>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_Manifestation_ReactorSaintDeparture</defName>
    <label>reactor saint cocoon departure</label>
    <description>The spent cocoon burning upward back into the breach.</description>
    <thingClass>RimWorld.Skyfaller</thingClass>
    <category>Ethereal</category>
    <tickerType>Normal</tickerType>
    <drawerType>RealtimeOnly</drawerType>
    <drawOffscreen>true</drawOffscreen>
    <useHitPoints>false</useHitPoints>
    <selectable>false</selectable>
    <altitudeLayer>Skyfaller</altitudeLayer>
    <graphicData>
      <texPath>Things/VFX/ReactorSaintArrival/ABY_ReactorSaintCocoon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutFlying</shaderType>
      <drawSize>(15.95,23.10)</drawSize>
    </graphicData>
    <skyfaller>
      <reversed>true</reversed>
      <ticksToDiscardInReverse>55</ticksToDiscardInReverse>
      <movementType>Accelerate</movementType>
      <speed>0.90</speed>
      <shadow>Things/Skyfaller/SkyfallerShadowDropPod</shadow>
      <shadowSize>(23.10,23.10)</shadowSize>
      <motesPerCell>0</motesPerCell>
    </skyfaller>
  </ThingDef>

</Defs>
