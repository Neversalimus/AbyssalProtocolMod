<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_PhalanxDriver</defName>
    <label>phalanx driver</label>
    <description>A disciplined horde-pattern spike rifle built from war-lattice fragments. Instead of flooding the field with fire, it drives a short sequence of infernal penetrators through the target line, excelling at cracking dense frontliners and punishing static cover fights.</description>
    <techLevel>Spacer</techLevel>

    <graphicData>
      <texPath>Things/Weapon/ABY_PhalanxDriver</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.60,0.42)</drawSize>
    </graphicData>

    <soundInteract>Interact_ChargeRifle</soundInteract>

    <weaponTags>
      <li>Gun</li>
      <li>RangedHeavy</li>
      <li>SpacerGun</li>
    </weaponTags>

    <recipeMaker>
      <skillRequirements>
        <Crafting>9</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
    </recipeMaker>

    <costList>
      <ABY_HordeFragment>8</ABY_HordeFragment>
      <ABY_AbyssalResidue>22</ABY_AbyssalResidue>
      <Steel>70</Steel>
      <Plasteel>38</Plasteel>
      <ComponentIndustrial>3</ComponentIndustrial>
      <ComponentSpacer>1</ComponentSpacer>
    </costList>

    <statBases>
      <WorkToMake>42000</WorkToMake>
      <Mass>5.1</Mass>
      <MarketValue>2600</MarketValue>
      <AccuracyTouch>0.78</AccuracyTouch>
      <AccuracyShort>0.84</AccuracyShort>
      <AccuracyMedium>0.79</AccuracyMedium>
      <AccuracyLong>0.58</AccuracyLong>
      <RangedWeapon_Cooldown>2.85</RangedWeapon_Cooldown>
    </statBases>

    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_PhalanxSpikeProjectile</defaultProjectile>
        <warmupTime>1.25</warmupTime>
        <range>30.9</range>
        <burstShotCount>3</burstShotCount>
        <ticksBetweenBurstShots>7</ticksBetweenBurstShots>
        <soundCast>ABY_AshenPikeFire</soundCast>
        <muzzleFlashScale>11.2</muzzleFlashScale>
      </li>
    </verbs>

    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>1500</requiredResidue>
        <category>Weapons</category>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_PhalanxSpikeProjectile</defName>
    <label>phalanx spike</label>
    <graphicData>
      <texPath>Things/Projectile/ABY_PhalanxSpike</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.20,0.88)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>15</damageAmountBase>
      <armorPenetrationBase>0.68</armorPenetrationBase>
      <stoppingPower>1.35</stoppingPower>
      <speed>68</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>

</Defs>
