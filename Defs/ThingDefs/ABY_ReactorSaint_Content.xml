<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="AnimalThingBase">
    <defName>ABY_ReactorSaint</defName>
    <label>infernal reactor saint</label>
    <description>A colossal techno-infernal saint built around a bound reactor heart and armored missile shoulders. Even before its deeper combat systems are awakened, the chassis is already a towering mid-endgame boss shell intended to stand above ordinary abyssal troops.</description>
    <thingClass>Pawn</thingClass>
    <category>Pawn</category>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Pawn/ReactorSaint/ABY_ReactorSaint</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(4.35,4.35)</drawSize>
    </graphicData>
    <race>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>Animal</thinkTreeMain>
      <thinkTreeConstant>AnimalConstant</thinkTreeConstant>
      <hasGenders>false</hasGenders>
      <trainability>None</trainability>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <canBecomeShambler>false</canBecomeShambler>
      <hediffGiverSets>
        <li>OrganicStandard</li>
      </hediffGiverSets>
      <body>Human</body>
      <baseBodySize>1.95</baseBodySize>
      <baseHealthScale>3.10</baseHealthScale>
      <baseHungerRate>0.54</baseHungerRate>
      <fleshType>Normal</fleshType>
      <intelligence>ToolUser</intelligence>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <manhunterOnTameFailChance>0</manhunterOnTameFailChance>
      <gestationPeriodDays>18</gestationPeriodDays>
      <lifeExpectancy>320</lifeExpectancy>
      <foodType>OmnivoreHuman</foodType>
      <useMeatFrom>Human</useMeatFrom>
      <lifeStageAges Inherit="False">
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
    </race>
    <statBases>
      <MaxHitPoints>2650</MaxHitPoints>
      <MoveSpeed>3.80</MoveSpeed>
      <MeleeHitChance>0.88</MeleeHitChance>
      <MeleeDodgeChance>0.10</MeleeDodgeChance>
      <ArmorRating_Sharp>0.98</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.72</ArmorRating_Blunt>
      <ArmorRating_Heat>1.80</ArmorRating_Heat>
      <ComfyTemperatureMin>-35</ComfyTemperatureMin>
      <ComfyTemperatureMax>280</ComfyTemperatureMax>
      <Mass>3.40</Mass>
      <MarketValue>6400</MarketValue>
      <Flammability>0.00</Flammability>
      <PainShockThreshold>999</PainShockThreshold>
      <PsychicSensitivity>0</PsychicSensitivity>
      <ToxicResistance>1</ToxicResistance>
      <ShootingAccuracyPawn>1.18</ShootingAccuracyPawn>
    </statBases>
    <tools>
      <li>
        <label>reactor fist</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>30</power>
        <cooldownTime>2.2</cooldownTime>
        <chanceFactor>1.05</chanceFactor>
        <armorPenetration>0.30</armorPenetration>
      </li>
      <li>
        <label>saint claw</label>
        <capacities>
          <li>Scratch</li>
          <li>Blunt</li>
        </capacities>
        <power>22</power>
        <cooldownTime>1.9</cooldownTime>
        <chanceFactor>0.95</chanceFactor>
        <armorPenetration>0.22</armorPenetration>
      </li>
    </tools>
    <comps>
      <li Class="AbyssalProtocol.CompProperties_AbyssalPawnController">
        <archetype>BossJuggernaut</archetype>
        <minMeleeSkill>12</minMeleeSkill>
        <minShootingSkill>15</minShootingSkill>
        <preferredMinRange>10.5</preferredMinRange>
        <retreatSearchRadius>11</retreatSearchRadius>
        <preferRangedTargets>true</preferRangedTargets>
        <preferFarthestTargets>true</preferFarthestTargets>
        <holdPositionWhenTargeting>true</holdPositionWhenTargeting>
      </li>
      <li Class="AbyssalProtocol.CompProperties_AbyssalAutoHostile" />
      <li Class="AbyssalProtocol.CompProperties_ABY_ReactorSaintShooter">
        <directProjectileDefName>ABY_ReactorSaintBolt</directProjectileDefName>
        <barrageProjectileDefName>ABY_ReactorSaintBarrageShell</barrageProjectileDefName>
        <aimSoundDefName>ABY_ReactorSaintCharge</aimSoundDefName>
        <primaryFireSoundDefName>ABY_ReactorSaintVolleyFire</primaryFireSoundDefName>
        <barrageFireSoundDefName>ABY_ReactorSaintBarrageFire</barrageFireSoundDefName>
        <range>34.9</range>
        <scanIntervalTicks>15</scanIntervalTicks>
        <primaryWarmupTicks>60</primaryWarmupTicks>
        <primaryCooldownTicks>165</primaryCooldownTicks>
        <primaryBurstShotCount>3</primaryBurstShotCount>
        <ticksBetweenPrimaryShots>9</ticksBetweenPrimaryShots>
        <barrageWarmupTicks>78</barrageWarmupTicks>
        <barrageCooldownTicks>300</barrageCooldownTicks>
        <barrageShotCount>4</barrageShotCount>
        <ticksBetweenBarrageShots>14</ticksBetweenBarrageShots>
        <barrageScatterRadius>2.6</barrageScatterRadius>
        <barrageTargetClusterRadius>2.85</barrageTargetClusterRadius>
        <barrageClusterThreshold>2</barrageClusterThreshold>
        <barrageRandomChance>0.24</barrageRandomChance>
        <preferredMinRange>10.5</preferredMinRange>
        <retreatSearchRadius>11</retreatSearchRadius>
        <preferFarthestTargets>true</preferFarthestTargets>
        <preferRangedTargets>true</preferRangedTargets>
        <holdPositionWhenTargeting>true</holdPositionWhenTargeting>
      </li>
    </comps>
    <killedLeavings Inherit="False">
      <ABY_AbyssalResidue>28</ABY_AbyssalResidue>
    </killedLeavings>
  </ThingDef>

</Defs>
