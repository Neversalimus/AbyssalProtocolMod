        <label>reactor fist</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>30</power>
        <cooldownTime>2.2</cooldownTime>
        <chanceFactor>1.05</chanceFactor>
        <armorPenetration>0.30</armorPenetration>
      </li>
      <li>
        <label>saint claw</label>
        <capacities>
          <li>Scratch</li>
          <li>Blunt</li>
        </capacities>
        <power>22</power>
        <cooldownTime>1.9</cooldownTime>
