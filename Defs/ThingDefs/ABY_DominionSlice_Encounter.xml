<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_DominionSliceAnchor_Seal</defName>
    <label>seal anchor</label>
    <description>A dominion anchor that holds the Crown-Heart under a shielding law. While any seal anchor remains, the heart rejects direct damage.</description>
    <thingClass>AbyssalProtocol.Building_ABY_DominionSliceAnchor</thingClass>
    <category>Building</category>
    <drawerType>MapMeshAndRealTime</drawerType>
    <tickerType>Normal</tickerType>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <fillPercent>0.28</fillPercent>
    <rotatable>false</rotatable>
    <selectable>true</selectable>
    <useHitPoints>true</useHitPoints>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <graphicData>
      <texPath>Things/Building/DominionAnchors/ABY_DominionAnchor_Suppression</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2.2,2.2)</drawSize>
    </graphicData>
    <statBases>
      <MaxHitPoints>720</MaxHitPoints>
      <Mass>68</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <size>(1,1)</size>
    <thingCategories Inherit="False" />
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_DominionSliceAnchor">
        <role>Seal</role>
        <pulseIntervalTicks>225</pulseIntervalTicks>
        <glowTexPath>Things/Building/DominionAnchors/ABY_DominionAnchor_Suppression_Glow</glowTexPath>
        <glowDrawScale>2.44</glowDrawScale>
      </li>
    </modExtensions>
  </ThingDef>

