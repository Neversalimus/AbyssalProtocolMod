<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="AnimalThingBase">
    <defName>ABY_RiftSapper</defName>
    <label>rift sapper</label>
    <description>A breach-utility abyssal infantry form built to destabilize defended firing lines. Rift sappers advance behind lighter rushers, probe for weak cover, and drive infernal spike charges through barricades, doors and clustered defenders.</description>
    <thingClass>Pawn</thingClass>
    <category>Pawn</category>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Pawn/RiftSapper/ABY_RiftSapper</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(2.58,2.58)</drawSize>
    </graphicData>
    <race>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>Humanlike</thinkTreeMain>
      <thinkTreeConstant>HumanlikeConstant</thinkTreeConstant>
      <hasGenders>false</hasGenders>
      <trainability>None</trainability>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <canBecomeShambler>false</canBecomeShambler>
      <hediffGiverSets>
        <li>OrganicStandard</li>
      </hediffGiverSets>
      <body>Human</body>
      <baseBodySize>0.88</baseBodySize>
      <baseHealthScale>1.18</baseHealthScale>
      <baseHungerRate>0.44</baseHungerRate>
      <fleshType>Normal</fleshType>
      <intelligence>ToolUser</intelligence>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <manhunterOnTameFailChance>0</manhunterOnTameFailChance>
      <gestationPeriodDays>18</gestationPeriodDays>
      <lifeExpectancy>105</lifeExpectancy>
      <foodType>OmnivoreHuman</foodType>
      <useMeatFrom>Human</useMeatFrom>
      <lifeStageAges Inherit="False">
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
    </race>
    <statBases>
      <MaxHitPoints>420</MaxHitPoints>
      <MoveSpeed>4.36</MoveSpeed>
      <MeleeHitChance>0.68</MeleeHitChance>
      <MeleeDPS>5.4</MeleeDPS>
      <ArmorRating_Sharp>0.16</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.10</ArmorRating_Blunt>
      <ArmorRating_Heat>0.42</ArmorRating_Heat>
      <ComfyTemperatureMin>-16</ComfyTemperatureMin>
      <ComfyTemperatureMax>180</ComfyTemperatureMax>
      <Flammability>0.02</Flammability>
      <PainShockThreshold>0.90</PainShockThreshold>
      <ShootingAccuracyPawn>0.96</ShootingAccuracyPawn>
      <MarketValue>580</MarketValue>
      <Mass>0.72</Mass>
    </statBases>
    <tools>
      <li>
        <label>breach spike</label>
        <capacities>
          <li>Stab</li>
        </capacities>
        <power>10</power>
        <cooldownTime>1.80</cooldownTime>
        <chanceFactor>1.00</chanceFactor>
        <armorPenetration>0.14</armorPenetration>
      </li>
      <li>
        <label>gauntlet smash</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>7</power>
        <cooldownTime>2.10</cooldownTime>
        <chanceFactor>0.78</chanceFactor>
        <armorPenetration>0.10</armorPenetration>
      </li>
    </tools>
    <killedLeavings Inherit="False">
      <ABY_AbyssalResidue>9</ABY_AbyssalResidue>
    </killedLeavings>
    <comps>
      <li Class="AbyssalProtocol.CompProperties_AbyssalPawnController">
        <archetype>RangedSkirmisher</archetype>
        <forcedPrimaryDefName>ABY_BreachSpikeProjector</forcedPrimaryDefName>
        <minMeleeSkill>9</minMeleeSkill>
        <minShootingSkill>8</minShootingSkill>
        <preferredMinRange>7.2</preferredMinRange>
        <retreatSearchRadius>9</retreatSearchRadius>
        <preferRangedTargets>true</preferRangedTargets>
        <useSapperAssaultLord>true</useSapperAssaultLord>
      </li>
      <li Class="AbyssalProtocol.CompProperties_AbyssalAutoHostile" />
      <li Class="AbyssalProtocol.CompProperties_ABY_RiftSapperShooter">
        <projectileDefName>ABY_RiftSapperSpike</projectileDefName>
        <aimSoundDefName>ABY_RiftCarbineCharge</aimSoundDefName>
        <castSoundDefName>ABY_AshenScattergunFire</castSoundDefName>
        <range>18.5</range>
        <warmupTicks>58</warmupTicks>
        <cooldownTicks>138</cooldownTicks>
        <scanIntervalTicks>15</scanIntervalTicks>
        <preferredMinRange>7.2</preferredMinRange>
        <targetMinRange>4.6</targetMinRange>
        <retreatSearchRadius>9</retreatSearchRadius>
        <panicMeleeRange>2.0</panicMeleeRange>
        <panicMeleeJobExpiryTicks>135</panicMeleeJobExpiryTicks>
        <preferRangedTargets>true</preferRangedTargets>
        <preferBuildingTargets>true</preferBuildingTargets>
        <prioritizeTurrets>true</prioritizeTurrets>
        <prioritizeDoors>true</prioritizeDoors>
        <prioritizeCover>true</prioritizeCover>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_BreachSpikeProjector</defName>
    <label>breach spike projector</label>
    <description>A compact infernal breaching armature that hurls heated spike charges into cover lines. Rift sappers use it to break doors, punish clustered firing positions and expose barricaded defenders for the rest of the abyssal host.</description>
    <graphicData>
      <texPath>Things/Weapon/ABY_RiftSapperProjector</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_ChargeRifle</soundInteract>
    <techLevel>Spacer</techLevel>
    <destroyOnDrop>true</destroyOnDrop>
    <tradeability>None</tradeability>
    <weaponTags>
      <li>ABY_BreachSpikeProjector</li>
      <li>Gun</li>
      <li>RangedHeavy</li>
    </weaponTags>
    <costList>
      <Steel>45</Steel>
      <Plasteel>16</Plasteel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <smeltProducts>
      <Steel>18</Steel>
      <Plasteel>6</Plasteel>
    </smeltProducts>
    <statBases>
      <Mass>3.05</Mass>
      <MarketValue>820</MarketValue>
      <AccuracyTouch>0.82</AccuracyTouch>
      <AccuracyShort>0.68</AccuracyShort>
      <AccuracyMedium>0.48</AccuracyMedium>
      <AccuracyLong>0.26</AccuracyLong>
      <RangedWeapon_Cooldown>2.65</RangedWeapon_Cooldown>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_RiftSapperSpike</defaultProjectile>
        <warmupTime>1.34</warmupTime>
        <range>18.5</range>
        <burstShotCount>1</burstShotCount>
        <ticksBetweenBurstShots>8</ticksBetweenBurstShots>
        <soundAiming>ABY_RiftCarbineCharge</soundAiming>
        <soundCast>ABY_AshenScattergunFire</soundCast>
        <soundCastTail>ABY_SigilRepeaterTail</soundCastTail>
        <muzzleFlashScale>8</muzzleFlashScale>
      </li>
    </verbs>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_RiftSapperSpike</defName>
    <label>breach spike charge</label>
    <thingClass>AbyssalProtocol.Projectile_RiftSapperSpike</thingClass>
    <graphicData>
      <texPath>Things/Projectile/ABY_RiftSapperSpike</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.32,1.26)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Burn</damageDef>
      <damageAmountBase>9</damageAmountBase>
      <armorPenetrationBase>0.22</armorPenetrationBase>
      <stoppingPower>0.82</stoppingPower>
      <speed>40</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>
</Defs>
