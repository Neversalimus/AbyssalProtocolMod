<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_SigilVault</defName>
    <label>abyssal sigil vault</label>
    <description>A compact infernal reliquary for isolated summon sigils. It stores up to twenty individual sigils inside a shielded containment core, visually displays its stored sample on top, and can be permanently linked to a specific abyssal summoning circle for direct ritual staging.</description>
    <thingClass>AbyssalProtocol.Building_ABY_SigilVault</thingClass>
    <category>Building</category>
    <drawerType>MapMeshAndRealTime</drawerType>

    <graphicData>
      <texPath>Things/Building/ABY_SigilVault</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2.0,2.0)</drawSize>
    </graphicData>

    <size>(2,2)</size>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <fillPercent>0.18</fillPercent>
    <pathCost>6</pathCost>
    <passability>PassThroughOnly</passability>
    <surfaceType>Item</surfaceType>
    <selectable>true</selectable>
    <drawGUIOverlay>false</drawGUIOverlay>

    <designationCategory>Furniture</designationCategory>
    <uiOrder>2550</uiOrder>
    <constructEffect>ConstructMetal</constructEffect>
    <castEdgeShadows>false</castEdgeShadows>
    <repairEffect>Repair</repairEffect>

    <costList>
      <Steel>70</Steel>
      <Plasteel>18</Plasteel>
      <ComponentIndustrial>2</ComponentIndustrial>
      <ABY_AbyssalResidue>10</ABY_AbyssalResidue>
    </costList>

    <statBases>
      <WorkToBuild>2400</WorkToBuild>
      <MaxHitPoints>220</MaxHitPoints>
      <Flammability>0.08</Flammability>
      <Beauty>-1</Beauty>
      <Mass>35</Mass>
    </statBases>

    <building>
      <isInert>true</isInert>
      <preventDeteriorationOnTop>true</preventDeteriorationOnTop>
      <paintable>false</paintable>
    </building>
</ThingDef>

</Defs>
