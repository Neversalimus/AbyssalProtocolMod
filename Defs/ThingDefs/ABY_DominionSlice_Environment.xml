  <ThingDef ParentName="BuildingBase">
    <defName>ABY_DominionSliceSigilPad</defName>
    <label>dominion sigil pad</label>
    <description>A plated sigil dais used to mark entry, extraction, anchor and heart positions inside the dominion slice.</description>
    <thingClass>Building</thingClass>
    <category>Building</category>
    <drawerType>MapMeshOnly</drawerType>
    <tickerType>Never</tickerType>
    <altitudeLayer>FloorEmplacement</altitudeLayer>
