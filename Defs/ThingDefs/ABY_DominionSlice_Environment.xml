  <ThingDef ParentName="BuildingBase">
    <defName>ABY_DominionSlicePerimeterWall</defName>
    <label>dominion perimeter wall</label>
    <description>A dense dominion barrier segment fused into the slice boundary. It exists to deny escape through the map edge and hold the encounter inside the infernal machine-domain.</description>
    <thingClass>Building</thingClass>
    <category>Building</category>
    <drawerType>MapMeshOnly</drawerType>
    <tickerType>Never</tickerType>
    <altitudeLayer>Building</altitudeLayer>
