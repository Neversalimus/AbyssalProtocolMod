<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_DominionSliceBastion</defName>
    <label>dominion bastion fragment</label>
    <description>A jagged fragment of dominion architecture, used to frame the slice as a shattered machine-temple rather than a copied void finale.</description>
    <thingClass>Building</thingClass>
    <category>Building</category>
    <drawerType>MapMeshOnly</drawerType>
    <tickerType>Never</tickerType>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <fillPercent>1</fillPercent>
    <rotatable>false</rotatable>
    <selectable>false</selectable>
    <canOverlapZones>true</canOverlapZones>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <graphicData>
      <texPath>Things/Building/DominionSlice/ABY_DominionSlice_Bastion</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2.8,2.8)</drawSize>
    </graphicData>
    <statBases>
      <MaxHitPoints>2000</MaxHitPoints>
      <Mass>25</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <size>(1,1)</size>
    <thingCategories Inherit="False" />
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_DominionSliceSpire</defName>
    <label>dominion spire</label>
