<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_CrudeStabilizerModule</defName>
    <label>crude stabilizer module</label>
    <description>A heavy edge-locking cassette for the abyssal summoning circle. Crude stabilizers are industrial restraint blocks wrapped around a glowing infernal core, meant to give the first containment lattice something to bite into.</description>
    <graphicData>
      <texPath>Things/Item/ABY_CrudeStabilizerModule</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>10</stackLimit>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <statBases>
      <MarketValue>185</MarketValue>
      <Mass>1.05</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalCircleModule">
        <moduleFamily>Stabilizer</moduleFamily>
        <tier>1</tier>
        <containmentBonus>0.10</containmentBonus>
        <ritualHeatMultiplier>0.96</ritualHeatMultiplier>
        <contaminationMultiplier>0.98</contaminationMultiplier>
        <mountedTexPath>Things/Building/Modules/ABY_CircleStabilizer_Crude_Mounted</mountedTexPath>
        <mountedDrawScale>1.14</mountedDrawScale>
        <glowTexPath>Things/Building/Modules/ABY_CircleStabilizer_Crude_Glow</glowTexPath>
        <glowDrawScale>1.28</glowDrawScale>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_ResonantStabilizerModule</defName>
    <label>resonant stabilizer module</label>
    <description>A tuned infernal-tech stabilizer cassette built around a segmented resonance spine. It does not merely clamp the breach geometry; it teaches the circle to hold one shape instead of screaming in all directions at once.</description>
    <graphicData>
      <texPath>Things/Item/ABY_ResonantStabilizerModule</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>10</stackLimit>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <statBases>
      <MarketValue>325</MarketValue>
      <Mass>1.20</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalCircleModule">
        <moduleFamily>Stabilizer</moduleFamily>
        <tier>2</tier>
        <containmentBonus>0.16</containmentBonus>
        <ritualHeatMultiplier>0.92</ritualHeatMultiplier>
        <contaminationMultiplier>0.90</contaminationMultiplier>
        <mountedTexPath>Things/Building/Modules/ABY_CircleStabilizer_Resonant_Mounted</mountedTexPath>
        <mountedDrawScale>1.16</mountedDrawScale>
        <glowTexPath>Things/Building/Modules/ABY_CircleStabilizer_Resonant_Glow</glowTexPath>
        <glowDrawScale>1.32</glowDrawScale>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_CrownStabilizerModule</defName>
    <label>crown stabilizer module</label>
    <description>A crown-tier restraint engine for the outer ring. Its spined vanes and focused infernal emitter are designed for circles expected to survive elite breach geometry instead of collapsing into self-harm and residue blowback.</description>
    <graphicData>
      <texPath>Things/Item/ABY_CrownStabilizerModule</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>10</stackLimit>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <statBases>
      <MarketValue>540</MarketValue>
      <Mass>1.45</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalCircleModule">
        <moduleFamily>Stabilizer</moduleFamily>
        <tier>3</tier>
        <containmentBonus>0.22</containmentBonus>
        <ritualHeatMultiplier>0.88</ritualHeatMultiplier>
        <contaminationMultiplier>0.82</contaminationMultiplier>
        <mountedTexPath>Things/Building/Modules/ABY_CircleStabilizer_Crown_Mounted</mountedTexPath>
        <mountedDrawScale>1.20</mountedDrawScale>
        <glowTexPath>Things/Building/Modules/ABY_CircleStabilizer_Crown_Glow</glowTexPath>
        <glowDrawScale>1.38</glowDrawScale>
      </li>
    </modExtensions>
  </ThingDef>

</Defs>
