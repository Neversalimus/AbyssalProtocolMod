<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_AnchorSpiker</defName>
    <label>anchor spiker</label>
    <description>A techno-infernal harpoon rifle built around a caged rift chamber and a brutal anchor-spike launch assembly. It fires a single stabilized breach spike with strong armor cracking power, giving the forge a deliberate mid-high tier marksman option that feels heavier than a needler but lighter and more practical than a breach cannon.</description>
    <techLevel>Spacer</techLevel>
    <graphicData>
      <texPath>Things/Weapon/ABY_AnchorSpiker</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.98,0.74)</drawSize>
    </graphicData>
    <soundInteract>Interact_ChargeRifle</soundInteract>
    <weaponTags>
      <li>Gun</li>
      <li>RangedHeavy</li>
      <li>SpacerGun</li>
    </weaponTags>
    <recipeMaker>
      <skillRequirements>
        <Crafting>10</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
    </recipeMaker>
    <costList>
      <ABY_AbyssalResidue>24</ABY_AbyssalResidue>
      <Steel>80</Steel>
      <Plasteel>64</Plasteel>
      <ComponentIndustrial>4</ComponentIndustrial>
      <Gold>12</Gold>
    </costList>
    <statBases>
      <WorkToMake>31500</WorkToMake>
      <Mass>4.65</Mass>
      <MarketValue>2780</MarketValue>
      <AccuracyTouch>0.56</AccuracyTouch>
      <AccuracyShort>0.81</AccuracyShort>
      <AccuracyMedium>0.77</AccuracyMedium>
      <AccuracyLong>0.51</AccuracyLong>
      <RangedWeapon_Cooldown>2.95</RangedWeapon_Cooldown>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_AnchorSpikeProjectile</defaultProjectile>
        <warmupTime>1.35</warmupTime>
        <range>29.9</range>
        <burstShotCount>1</burstShotCount>
        <ticksBetweenBurstShots>10</ticksBetweenBurstShots>
        <soundCast>Shot_ChargeRifle</soundCast>
        <muzzleFlashScale>11.2</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>frame</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2.1</cooldownTime>
      </li>
    </tools>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>425</requiredResidue>
        <category>Weapons</category>
      </li>
    </modExtensions>
  </ThingDef>
  <ThingDef ParentName="BaseBullet">
    <defName>ABY_AnchorSpikeProjectile</defName>
    <label>anchor spike</label>
    <graphicData>
      <texPath>Things/Projectile/ABY_AnchorSpike</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.42,1.14)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>23</damageAmountBase>
      <armorPenetrationBase>0.72</armorPenetrationBase>
      <stoppingPower>1.90</stoppingPower>
      <speed>66</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>
</Defs>
