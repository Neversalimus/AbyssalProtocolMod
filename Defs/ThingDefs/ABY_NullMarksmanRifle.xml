<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_NullMarksmanRifle</defName>
    <label>null marksman rifle</label>
    <description>A precision abyssal rifle built around a null-aligned breach lens. Its shots do not overpower armor directly — they briefly convince the target's surface that continuity is optional.</description>
    <techLevel>Spacer</techLevel>

    <graphicData>
      <texPath>Things/Weapon/ABY_NullMarksmanRifle</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.58,0.40)</drawSize>
    </graphicData>

    <soundInteract>Interact_ChargeRifle</soundInteract>

    <weaponTags>
      <li>Gun</li>
      <li>RangedHeavy</li>
      <li>SpacerGun</li>
    </weaponTags>

    <recipeMaker>
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
    </recipeMaker>

    <costList>
      <ABY_AbyssalResidue>16</ABY_AbyssalResidue>
      <Plasteel>55</Plasteel>
      <Steel>35</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
      <Gold>10</Gold>
    </costList>

    <statBases>
      <WorkToMake>26000</WorkToMake>
      <Mass>3.9</Mass>
      <MarketValue>2100</MarketValue>
      <AccuracyTouch>0.50</AccuracyTouch>
      <AccuracyShort>0.78</AccuracyShort>
      <AccuracyMedium>0.88</AccuracyMedium>
      <AccuracyLong>0.82</AccuracyLong>
      <RangedWeapon_Cooldown>2.25</RangedWeapon_Cooldown>
    </statBases>

    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_NullMarksmanSpikeProjectile</defaultProjectile>
        <warmupTime>1.45</warmupTime>
        <range>33.9</range>
        <burstShotCount>1</burstShotCount>
        <ticksBetweenBurstShots>10</ticksBetweenBurstShots>
        <soundCast>Shot_ChargeRifle</soundCast>
        <muzzleFlashScale>10.8</muzzleFlashScale>
      </li>
    </verbs>

    <tools>
      <li>
        <label>frame</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>8</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>

    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>275</requiredResidue>
        <category>Weapons</category>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_NullMarksmanSpikeProjectile</defName>
    <label>null marksman spike</label>
    <graphicData>
      <texPath>Things/Projectile/ABY_NullMarksmanSpike</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.28,1.18)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>19</damageAmountBase>
      <armorPenetrationBase>0.60</armorPenetrationBase>
      <stoppingPower>1.25</stoppingPower>
      <speed>72</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>

</Defs>
