<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_DominionSigil</defName>
    <label>dominion sigil</label>
    <description>An endgame crown-lattice invocation key. Carry it to an abyssal summoning circle to bootstrap the Great Infernal Gate staging sequence and initialize the first dominion breach package.</description>
    <thingClass>AbyssalProtocol.Thing_AbyssalAnimatedItem</thingClass>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Things/Item/ABY_DominionSigil</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>10</stackLimit>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <statBases>
      <MarketValue>620</MarketValue>
      <Mass>0.36</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <comps>
      <li Class="CompProperties_Usable">
        <useJob>ABY_CarrySigilToCircle</useJob>
        <useLabel>bootstrap great infernal gate</useLabel>
      </li>
      <li Class="AbyssalProtocol.CompProperties_UseEffectSummonBoss">
        <ritualId>dominion_gate</ritualId>
        <summonMode>DominionCrisis</summonMode>
        <bossLabel>Great Infernal Gate staging</bossLabel>
        <spawnPoints>1600</spawnPoints>
        <ritualWarmupTicks>210</ritualWarmupTicks>
      </li>
    </comps>
  </ThingDef>

</Defs>
