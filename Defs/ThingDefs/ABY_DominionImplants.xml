<Defs>

  <ThingDef ParentName="BodyPartBionicBase">
    <defName>ABY_CrownCortexSubnode</defName>
    <label>crown cortex subnode</label>
    <description>An auxiliary dominion cognition module forged around a crown shard and seated beside the brain instead of replacing it. It deepens ordered thought, pattern recognition and calm pre-combat timing while leaving the host's original mind intact.</description>
    <graphicData>
      <texPath>Things/Implant/ABY_CrownCortexSubnode</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>1</stackLimit>
    <tradeability>Sellable</tradeability>
    <techLevel>Spacer</techLevel>
    <statBases>
      <Mass>0.18</Mass>
      <WorkToMake>52000</WorkToMake>
      <MarketValue>3520</MarketValue>
      <Flammability>0</Flammability>
    </statBases>
    <recipeMaker>
      <skillRequirements>
        <Crafting>13</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
      <unfinishedThingDef>UnfinishedHealthItemBionic</unfinishedThingDef>
    </recipeMaker>
    <costList>
      <ABY_DominionCrownShard>1</ABY_DominionCrownShard>
      <Plasteel>30</Plasteel>
      <ComponentSpacer>2</ComponentSpacer>
      <Gold>20</Gold>
    </costList>
    <comps>
      <li Class="AbyssalProtocol.CompProperties_ABY_ImplantInfoCard" />
    </comps>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>3500</requiredResidue>
        <category>Implants</category>
      </li>
    </modExtensions>
  </ThingDef>

