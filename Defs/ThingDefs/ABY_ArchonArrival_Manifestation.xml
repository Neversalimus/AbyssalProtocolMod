<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_Manifestation_ArchonBeastArrival</defName>
    <label>archon beast manifestation</label>
    <description>A rupture seam widening near the colony, just wide enough for a chained herald-predator to force its way through.</description>
    <thingClass>AbyssalProtocol.Building_ABY_ArchonBeastManifestation</thingClass>
    <category>Building</category>
    <graphicData>
      <texPath>Things/VFX/Manifestation/ABY_Manifestation_Invisible</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>TransparentPostLight</shaderType>
      <drawSize>(1.0,1.0)</drawSize>
    </graphicData>
    <tickerType>Normal</tickerType>
    <fillPercent>0.01</fillPercent>
    <passability>PassThroughOnly</passability>
    <selectable>false</selectable>
    <useHitPoints>false</useHitPoints>
    <rotatable>false</rotatable>
    <altitudeLayer>MetaOverlays</altitudeLayer>
    <drawOffscreen>true</drawOffscreen>
  </ThingDef>

</Defs>
