<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="ApparelBase">
    <defName>ABY_AshboundTreadBoots</defName>
    <thingClass>Apparel</thingClass>
    <label>ashbound tread boots</label>
    <description>Early abyssal tread boots built from steel sole plates, residue-laced shock pads and crude ember stabilizers. They are not elegant, but they let a colonist carry more, move faster and keep their footing near machines that were never meant to be safe.</description>
    <techLevel>Ultra</techLevel>
    <graphicData>
      <texPath>Things/Item/Apparel/ABY_AshboundTreadBoots</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.82,0.82)</drawSize>
    </graphicData>
    <apparel>
      <bodyPartGroups>
        <li>Legs</li>
      </bodyPartGroups>
      <layers>
        <li>Belt</li>
      </layers>
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
    </apparel>
    <tradeability>Sellable</tradeability>
    <smeltable>true</smeltable>
    <smeltProducts>
      <Steel>10</Steel>
    </smeltProducts>
    <equippedStatOffsets>
      <MoveSpeed>0.08</MoveSpeed>
      <CarryingCapacity>8</CarryingCapacity>
    </equippedStatOffsets>
    <statBases>
      <WorkToMake>950</WorkToMake>
      <MaxHitPoints>135</MaxHitPoints>
      <Mass>0.95</Mass>
      <MarketValue>320</MarketValue>
      <ArmorRating_Sharp>0.04</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.03</ArmorRating_Blunt>
      <ArmorRating_Heat>0.06</ArmorRating_Heat>
    </statBases>
  </ThingDef>

