<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="AnimalThingBase">
    <defName>ABY_HaloHusk</defName>
    <label>halo husk</label>
    <description>A rare angelic wreck-form dragged through abyssal breach geometry and forced into hostile service. Halo husks do not behave like ordinary abyssal infantry: they arrive in silence, spear one firing lane with disciplined lance fire, and stand just outside the normal shape of the host.</description>
    <thingClass>Pawn</thingClass>
    <category>Pawn</category>
    <drawerType>RealtimeOnly</drawerType>

    <graphicData>
      <texPath>Pawn/HaloHusk/ABY_HaloHusk</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(4.10,4.10)</drawSize>
    </graphicData>

    <race>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>Animal</thinkTreeMain>
      <thinkTreeConstant>AnimalConstant</thinkTreeConstant>
      <hasGenders>false</hasGenders>
      <trainability>None</trainability>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <canBecomeShambler>false</canBecomeShambler>
      <hediffGiverSets>
        <li>OrganicStandard</li>
      </hediffGiverSets>
      <body>Human</body>
      <baseBodySize>0.96</baseBodySize>
      <baseHealthScale>1.22</baseHealthScale>
      <baseHungerRate>0.42</baseHungerRate>
      <fleshType>Normal</fleshType>
      <intelligence>ToolUser</intelligence>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <manhunterOnTameFailChance>0</manhunterOnTameFailChance>
      <gestationPeriodDays>18</gestationPeriodDays>
      <lifeExpectancy>145</lifeExpectancy>
      <foodType>OmnivoreHuman</foodType>
      <useMeatFrom>Human</useMeatFrom>
      <lifeStageAges Inherit="False">
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
    </race>

    <statBases>
      <MaxHitPoints>620</MaxHitPoints>
      <MoveSpeed>4.82</MoveSpeed>
      <MeleeHitChance>0.66</MeleeHitChance>
      <MeleeDPS>3.9</MeleeDPS>
      <MeleeDodgeChance>0.12</MeleeDodgeChance>
      <ArmorRating_Sharp>0.28</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.16</ArmorRating_Blunt>
      <ArmorRating_Heat>0.62</ArmorRating_Heat>
      <ComfyTemperatureMin>-24</ComfyTemperatureMin>
      <ComfyTemperatureMax>240</ComfyTemperatureMax>
      <Flammability>0.00</Flammability>
      <PainShockThreshold>0.90</PainShockThreshold>
      <ShootingAccuracyPawn>1.12</ShootingAccuracyPawn>
      <MarketValue>1240</MarketValue>
      <Mass>0.72</Mass>
    </statBases>

    <tools>
      <li>
        <label>charred lance haft</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>8</power>
        <cooldownTime>2.15</cooldownTime>
        <chanceFactor>0.92</chanceFactor>
        <armorPenetration>0.10</armorPenetration>
      </li>
    </tools>
    <killedLeavings Inherit="False">
      <ABY_AbyssalResidue>10</ABY_AbyssalResidue>
    </killedLeavings>

<comps>
      <li Class="AbyssalProtocol.CompProperties_AbyssalPawnController">
        <archetype>RangedSkirmisher</archetype>
        <minShootingSkill>11</minShootingSkill>
        <preferredMinRange>8.8</preferredMinRange>
        <retreatSearchRadius>10</retreatSearchRadius>
        <preferRangedTargets>true</preferRangedTargets>
        <holdPositionWhenTargeting>true</holdPositionWhenTargeting>
      </li>
      <li Class="AbyssalProtocol.CompProperties_AbyssalAutoHostile" />

      <li Class="AbyssalProtocol.CompProperties_ABY_HaloJudgment">
        <initialWarmupTicks>420</initialWarmupTicks>
        <markCooldownTicks>1260</markCooldownTicks>
        <markCooldownVariance>180</markCooldownVariance>
        <markDurationTicks>600</markDurationTicks>
        <scanIntervalTicks>18</scanIntervalTicks>
        <minTargetRange>7.5</minTargetRange>
        <maxTargetRange>24.5</maxTargetRange>
        <preferRangedTargets>true</preferRangedTargets>
        <markHediffDefName>ABY_HaloJudgmentMarked</markHediffDefName>
        <soundDefName>ABY_RuptureVerdict</soundDefName>
        <applicationVisualScale>1.35</applicationVisualScale>
        <minRefreshTicksRemaining>180</minRefreshTicksRemaining>
      </li>
      <li Class="AbyssalProtocol.CompProperties_ABY_HaloStep">
        <scanIntervalTicks>12</scanIntervalTicks>
        <cooldownTicks>840</cooldownTicks>
        <cooldownVarianceTicks>120</cooldownVarianceTicks>
        <triggerEnemyRange>3.25</triggerEnemyRange>
        <minStepDistance>4.6</minStepDistance>
        <maxStepDistance>7.8</maxStepDistance>
        <avoidEnemyRadius>4.2</avoidEnemyRadius>
        <damageThreshold>18</damageThreshold>
        <damageWindowTicks>90</damageWindowTicks>
        <visualScale>1.35</visualScale>
      </li>
      <li Class="AbyssalProtocol.CompProperties_ABY_HaloFracture">
        <radius>3.1</radius>
        <maxTargets>6</maxTargets>
        <hediffDurationTicks>240</hediffDurationTicks>
        <hediffDefName>ABY_HaloFractureDazzled</hediffDefName>
        <soundDefName>ABY_SigilChargePulse</soundDefName>
        <visualScale>1.25</visualScale>
      </li>
      <li Class="AbyssalProtocol.CompProperties_HexgunThrallShooter">
        <projectileDefName>ABY_HaloLanceBolt</projectileDefName>
        <aimSoundDefName>ABY_RiftCarbineCharge</aimSoundDefName>
        <castSoundDefName>ABY_RiftCarbineFire</castSoundDefName>
        <range>26.5</range>
        <warmupTicks>72</warmupTicks>
        <cooldownTicks>138</cooldownTicks>
        <burstShotCount>1</burstShotCount>
        <ticksBetweenBurstShots>1</ticksBetweenBurstShots>
        <scanIntervalTicks>18</scanIntervalTicks>
        <preferredMinRange>8.8</preferredMinRange>
        <retreatSearchRadius>10</retreatSearchRadius>
        <preferRangedTargets>true</preferRangedTargets>
        <holdPositionWhenTargeting>true</holdPositionWhenTargeting>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_HaloLanceBolt</defName>
    <label>halo lance bolt</label>
    <graphicData>
      <texPath>Things/Projectile/ABY_HaloLanceBolt</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.28,1.42)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Burn</damageDef>
      <damageAmountBase>18</damageAmountBase>
      <armorPenetrationBase>0.26</armorPenetrationBase>
      <stoppingPower>0.92</stoppingPower>
      <speed>82</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>

</Defs>
