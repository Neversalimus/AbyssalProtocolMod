<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_UltraPlasmaRifle</defName>
    <label>ultra plasma rifle</label>
    <description>An ultra-tech plasma rifle with a reinforced triple long barrel and four thermal tubes. It fires custom cyan plasma bolts with extreme armor penetration. Repeated hits destabilize the target into a short-lived plasma overload.</description>
    <techLevel>Spacer</techLevel>

    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/PlasmaRifle_UHT</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <soundInteract>Interact_ChargeRifle</soundInteract>

    <statBases>
      <WorkToMake>90000</WorkToMake>
      <Mass>6.5</Mass>
      <AccuracyTouch>0.58</AccuracyTouch>
      <AccuracyShort>0.70</AccuracyShort>
      <AccuracyMedium>0.62</AccuracyMedium>
      <AccuracyLong>0.50</AccuracyLong>
      <RangedWeapon_Cooldown>2.10</RangedWeapon_Cooldown>
    </statBases>

    <recipeMaker>
      <researchPrerequisite>ChargedShot</researchPrerequisite>
      <skillRequirements>
        <Crafting>10</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
    </recipeMaker>

    <costList>
      <Plasteel>500</Plasteel>
      <ComponentSpacer>12</ComponentSpacer>
      <Steel>750</Steel>
    </costList>

    <weaponTags>
      <li>SpacerGun</li>
    </weaponTags>

    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_UltraPlasmaBeamBurst</defaultProjectile>
        <warmupTime>1.10</warmupTime>
        <range>28.9</range>
        <ticksBetweenBurstShots>9</ticksBetweenBurstShots>
        <burstShotCount>3</burstShotCount>
        <soundAiming>ABY_UltraPlasmaCharge</soundAiming>
        <soundCast>ABY_UltraPlasmaFire</soundCast>
        <soundCastTail>ABY_UltraPlasmaTail</soundCastTail>
        <muzzleFlashScale>11</muzzleFlashScale>
      </li>
    </verbs>

    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>10</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>10</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_UltraPlasmaBolt</defName>
    <label>ultra plasma bolt</label>
    <thingClass>Bullet</thingClass>
    <graphicData>
      <texPath>Things/Projectile/UltraPlasmaBolt</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.22,1.15)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Burn</damageDef>
      <damageAmountBase>20</damageAmountBase>
      <armorPenetrationBase>1.25</armorPenetrationBase>
      <stoppingPower>1.9</stoppingPower>
      <speed>85</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_UltraPlasmaBeamBurst</defName>
    <label>ultra plasma beam</label>
    <thingClass>AbyssalProtocol.Projectile_UltraPlasmaBurst</thingClass>
    <graphicData>
      <texPath>Things/Projectile/ABY_UltraPlasmaBeam_Long</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.34,2.75)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Burn</damageDef>
      <damageAmountBase>20</damageAmountBase>
      <armorPenetrationBase>1.25</armorPenetrationBase>
      <stoppingPower>1.9</stoppingPower>
      <speed>46</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>

</Defs>
