<Defs>

  <ThingDef ParentName="ApparelBase">
    <defName>ABY_AshboundFieldPack</defName>
    <thingClass>Apparel</thingClass>
    <label>ashbound field pack</label>
    <description>A crude abyssal field pack built from residue-lined metal, sealed ember canisters and reinforced harness anchors. It is not a true reactor: it is a low-tier logistics frame that lets an operator carry more breach gear without turning the wearer into a walking altar.</description>
    <techLevel>Ultra</techLevel>
    <graphicData>
      <texPath>Things/Item/Apparel/ABY_AshboundFieldPack</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.88,0.88)</drawSize>
    </graphicData>
    <apparel>
      <bodyPartGroups>
        <li>Waist</li>
      </bodyPartGroups>
      <layers>
        <li>Belt</li>
      </layers>
      <wornGraphicPath>Things/Apparel/ABY_AshboundFieldPack</wornGraphicPath>
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
    </apparel>
    <tradeability>Sellable</tradeability>
    <smeltable>true</smeltable>
    <smeltProducts>
      <Steel>14</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </smeltProducts>
    <equippedStatOffsets>
      <CarryingCapacity>20</CarryingCapacity>
      <MoveSpeed>0.08</MoveSpeed>
      <WorkSpeedGlobal>0.04</WorkSpeedGlobal>
      <MeleeDodgeChance>-0.03</MeleeDodgeChance>
    </equippedStatOffsets>
    <statBases>
      <WorkToMake>1300</WorkToMake>
      <MaxHitPoints>180</MaxHitPoints>
      <Mass>4.0</Mass>
      <MarketValue>450</MarketValue>
      <ArmorRating_Sharp>0.04</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.06</ArmorRating_Blunt>
      <ArmorRating_Heat>0.08</ArmorRating_Heat>
    </statBases>
  </ThingDef>

