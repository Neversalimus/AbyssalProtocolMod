<Defs>

  <ThingDef ParentName="BodyPartBionicBase">
    <defName>ABY_CohortSyncSubnode</defName>
    <label>cohort sync subnode</label>
    <description>An auxiliary war-lattice brain module forged from a stabilized horde fragment. Rather than replacing the mind, it nests beside it and keeps hostile pressure, squad timing and targeting rhythm in ordered alignment.</description>
    <graphicData>
      <texPath>Things/Implant/ABY_CohortSyncSubnode</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>1</stackLimit>
    <tradeability>Sellable</tradeability>
    <techLevel>Spacer</techLevel>
    <statBases>
      <Mass>0.16</Mass>
      <WorkToMake>38000</WorkToMake>
      <MarketValue>2240</MarketValue>
      <Flammability>0</Flammability>
    </statBases>
    <recipeMaker>
      <skillRequirements>
        <Crafting>11</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
      <unfinishedThingDef>UnfinishedHealthItemBionic</unfinishedThingDef>
    </recipeMaker>
    <costList>
      <ABY_HordeFragment>1</ABY_HordeFragment>
      <ComponentIndustrial>2</ComponentIndustrial>
      <ComponentSpacer>1</ComponentSpacer>
      <Plasteel>20</Plasteel>
      <Gold>8</Gold>
      <Silver>30</Silver>
    </costList>
    <comps>
      <li Class="AbyssalProtocol.CompProperties_ABY_ImplantInfoCard" />
    </comps>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>1000</requiredResidue>
        <category>Implants</category>
      </li>
    </modExtensions>
  </ThingDef>

