<Defs>

  <ThingDef ParentName="ApparelBase">
    <defName>ABY_SaintAegisCarapace</defName>
    <thingClass>Apparel</thingClass>
    <label>saint aegis carapace</label>
    <description>A rebuilt torso shell forged from salvaged Infernal Reactor Saint plating, reactor housings and scorched containment ribs. It still looks like it belonged on a walking artillery-saint first and a human body second. The result is heavy, unnervingly clean, and markedly better at surviving heat and high-energy punishment than the first infernal combat line.</description>
    <techLevel>Spacer</techLevel>
    <graphicData>
      <texPath>Things/Item/Apparel/ABY_SaintAegisCarapace</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.14,1.14)</drawSize>
    </graphicData>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
        <li>Neck</li>
      </bodyPartGroups>
      <layers>
        <li>Shell</li>
      </layers>
      <wornGraphicPath>Things/Apparel/ABY_SaintAegisCarapace</wornGraphicPath>
    </apparel>
    <tradeability>Sellable</tradeability>
    <smeltable>true</smeltable>
    <smeltProducts>
      <Plasteel>42</Plasteel>
      <Uranium>16</Uranium>
      <ComponentSpacer>2</ComponentSpacer>
      <Gold>4</Gold>
    </smeltProducts>
    <equippedStatOffsets>
      <MoveSpeed>-0.08</MoveSpeed>
    </equippedStatOffsets>
    <statBases>
      <WorkToMake>5800</WorkToMake>
      <MaxHitPoints>455</MaxHitPoints>
      <Mass>6.2</Mass>
      <MarketValue>4150</MarketValue>
      <ArmorRating_Sharp>1.04</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.54</ArmorRating_Blunt>
      <ArmorRating_Heat>0.92</ArmorRating_Heat>
    </statBases>
  </ThingDef>

