<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_AbyssalResidue</defName>
    <label>abyssal residue</label>
    <description>Condensed techno-occult slag. It is inert in storage, but resonates violently inside the summoning circle.</description>
    <graphicData>
      <texPath>Things/Item/ABY_AbyssalResidue</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <color>(255,80,80)</color>
    </graphicData>
    <tradeability>Buyable</tradeability>
    <stackLimit>75</stackLimit>
    <statBases>
      <MarketValue>12</MarketValue>
      <Mass>0.08</Mass>
      <Flammability>0</Flammability>
    </statBases>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_ArchonSigil</defName>
    <label>archon sigil</label>
    <description>A stabilized infernal key. Carry it to an abyssal summoning circle to charge the sigil and tear open a breach for the first techno-demonic boss.</description>
    <thingClass>AbyssalProtocol.Thing_AbyssalAnimatedItem</thingClass>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Things/Item/ABY_ArchonSigil</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>10</stackLimit>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <statBases>
      <MarketValue>320</MarketValue>
      <Mass>0.3</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <comps>
      <li Class="CompProperties_Usable">
        <useJob>ABY_CarrySigilToCircle</useJob>
        <useLabel>invoke archon</useLabel>
      </li>
      <li Class="AbyssalProtocol.CompProperties_UseEffectSummonBoss">
        <pawnKindDefName>ABY_ArchonBeast</pawnKindDefName>
        <bossLabel>Archon Beast</bossLabel>
        <spawnPoints>900</spawnPoints>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="BodyPartBionicBase">
    <defName>ABY_InfernalEye</defName>
    <label>infernal eye</label>
    <description>A red-black ocular implant with abyssal target prediction routines.</description>
    <graphicData>
      <texPath>Things/Implant/ABY_InfernalEye</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <Mass>0.15</Mass>
      <WorkToMake>26000</WorkToMake>
      <MarketValue>900</MarketValue>
    </statBases>
    <recipeMaker>
      <researchPrerequisite>ABY_AbyssalAugmentation</researchPrerequisite>
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_SummoningCircle</li>
      </recipeUsers>
      <unfinishedThingDef>UnfinishedHealthItemBionic</unfinishedThingDef>
    </recipeMaker>
    <costList>
      <ABY_AbyssalResidue>10</ABY_AbyssalResidue>
      <ComponentIndustrial>2</ComponentIndustrial>
      <Steel>30</Steel>
    </costList>
  </ThingDef>

  <ThingDef ParentName="DrugBase">
    <defName>ABY_ArchonOverrideAmpoule</defName>
    <label>archon override ampoule</label>
    <description>A captured combat ampoule distilled from the slain herald's abyssal core. It is intentionally tuned as the reward for the first boss only: a small, immediate combat edge rather than a permanent power spike. Injecting it floods a pawn with stolen archon targeting and locomotion routines, then leaves behind mild neural strain.</description>
    <graphicData>
      <texPath>Things/Item/ABY_ArchonOverrideAmpoule</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <rotatable>false</rotatable>
    <stackLimit>10</stackLimit>
    <tradeability>Sellable</tradeability>
    <techLevel>Ultra</techLevel>
    <statBases>
      <MarketValue>260</MarketValue>
      <Mass>0.06</Mass>
    </statBases>
    <comps>
      <li Class="CompProperties_Drug">
        <listOrder>2100</listOrder>
        <isCombatEnhancingDrug>true</isCombatEnhancingDrug>
      </li>
    </comps>
    <ingestible>
      <drugCategory>Medical</drugCategory>
      <foodType>Processed, Fluid</foodType>
      <baseIngestTicks>90</baseIngestTicks>
      <ingestSound>Ingest_Inject</ingestSound>
      <ingestCommandString>Inject {0}</ingestCommandString>
      <ingestReportString>Injecting {0}.</ingestReportString>
      <useEatingSpeedStat>false</useEatingSpeedStat>
      <chairSearchRadius>0</chairSearchRadius>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>ABY_ArchonOverrideSurge</hediffDef>
          <severity>1.0</severity>
        </li>
      </outcomeDoers>
    </ingestible>
  </ThingDef>


  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_CrownOfRupture</defName>
    <label>crown of rupture</label>
    <description>A collapsed crown-reactor torn from the hidden archon. It stores exactly one execution verdict at a time. Once fired, the crown needs a full in-game day to condense another charge. While equipped it slightly sharpens movement, aim and evasive timing, but its true value is the once-per-day Rupture Sentence.</description>
    <techLevel>Ultra</techLevel>
    <thingCategories Inherit="False">
      <li>WeaponsRanged</li>
    </thingCategories>
    <graphicData>
      <texPath>Things/Item/ABY_CrownOfRupture</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <soundInteract>Interact_ChargeRifle</soundInteract>
    <tradeability>Sellable</tradeability>
    <smeltable>false</smeltable>
    <recipeMaker Inherit="False">
      <recipeUsers Inherit="False">
      </recipeUsers>
    </recipeMaker>
    <costList>
      <Steel>1</Steel>
    </costList>
    <weaponTags>
      <li>SpacerGun</li>
      <li>Gun</li>
      <li>RangedHeavy</li>
    </weaponTags>
    <equippedStatOffsets>
      <MoveSpeed>0.08</MoveSpeed>
      <ShootingAccuracyPawn>0.08</ShootingAccuracyPawn>
      <MeleeDodgeChance>0.10</MeleeDodgeChance>
    </equippedStatOffsets>
    <statBases>
      <WorkToMake>50000</WorkToMake>
      <Mass>1.7</Mass>
      <MarketValue>6800</MarketValue>
      <AccuracyTouch>0.95</AccuracyTouch>
      <AccuracyShort>0.92</AccuracyShort>
      <AccuracyMedium>0.88</AccuracyMedium>
      <AccuracyLong>0.84</AccuracyLong>
      <RangedWeapon_Cooldown>1000.0</RangedWeapon_Cooldown>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_RuptureSentenceBolt</defaultProjectile>
        <warmupTime>1.65</warmupTime>
        <range>35.9</range>
        <burstShotCount>1</burstShotCount>
        <ticksBetweenBurstShots>1</ticksBetweenBurstShots>
        <soundCast>ABY_RuptureVerdict</soundCast>
        <muzzleFlashScale>12</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>crown edge</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>10</power>
        <cooldownTime>2.2</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_RuptureSentenceBolt</defName>
    <label>rupture sentence bolt</label>
    <thingClass>Bullet</thingClass>
    <graphicData>
      <texPath>Things/Projectile/UltraPlasmaBolt</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.30,1.30)</drawSize>
      <color>(255,70,70)</color>
    </graphicData>
    <projectile>
      <damageDef>ABY_RuptureSentence</damageDef>
      <damageAmountBase>48</damageAmountBase>
      <armorPenetrationBase>2.25</armorPenetrationBase>
      <stoppingPower>5.5</stoppingPower>
      <speed>90</speed>
      <soundImpactAnticipate>ABY_RuptureImpact</soundImpactAnticipate>
    </projectile>
  </ThingDef>

  <DamageDef ParentName="CutBase">
    <defName>ABY_RuptureSentence</defName>
    <label>rupture sentence</label>
    <externalViolence>true</externalViolence>
    <deathMessage>{0} was sentenced by a rupture crown.</deathMessage>
    <defaultDamage>48</defaultDamage>
    <additionalHediffs>
      <li>
        <hediff>ABY_RuptureSentenceMark</hediff>
        <severityPerDamageDealt>0.010</severityPerDamageDealt>
      </li>
    </additionalHediffs>
  </DamageDef>


</Defs>
