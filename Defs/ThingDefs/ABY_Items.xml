<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_AbyssalResidue</defName>
    <label>abyssal residue</label>
    <description>Condensed techno-occult slag. It is inert in storage, but resonates violently inside the summoning circle.</description>
    <graphicData>
      <texPath>Things/Item/ABY_AbyssalResidue</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <color>(255,80,80)</color>
    </graphicData>
    <tradeability>Buyable</tradeability>
    <stackLimit>75</stackLimit>
    <statBases>
      <MarketValue>12</MarketValue>
      <Mass>0.08</Mass>
      <Flammability>0</Flammability>
    </statBases>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_ArchonSigil</defName>
    <label>archon sigil</label>
    <description>A stabilized infernal key. Carry it to an abyssal summoning circle to charge the sigil and drag the first techno-demonic herald-beast into local space through a chained predatory rupture seam near the colony.</description>
    <thingClass>AbyssalProtocol.Thing_AbyssalAnimatedItem</thingClass>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Things/Item/ABY_ArchonSigil</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>10</stackLimit>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <statBases>
      <MarketValue>320</MarketValue>
      <Mass>0.3</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <comps>
      <li Class="CompProperties_Usable">
        <useJob>ABY_CarrySigilToCircle</useJob>
        <useLabel>invoke archon</useLabel>
      </li>
      <li Class="AbyssalProtocol.CompProperties_UseEffectSummonBoss">
        <ritualId>archon_beast</ritualId>
        <summonMode>Boss</summonMode>
        <pawnKindDefName>ABY_ArchonBeast</pawnKindDefName>
        <bossLabel>Archon Beast</bossLabel>
        <spawnPoints>900</spawnPoints>
        <ritualWarmupTicks>195</ritualWarmupTicks>
        <arrivalManifestationDefName>ABY_Manifestation_ArchonBeastArrival</arrivalManifestationDefName>
        <arrivalManifestationWarmupTicks>150</arrivalManifestationWarmupTicks>
        <arrivalNearColony>true</arrivalNearColony>
        <arrivalNearColonyMinDistance>12</arrivalNearColonyMinDistance>
        <arrivalNearColonyMaxDistance>24</arrivalNearColonyMaxDistance>
        <arrivalSoundDefName>ABY_ArchonBossArrive</arrivalSoundDefName>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_UnstableBreachSigil</defName>
    <label>unstable breach sigil</label>
    <description>A volatile infernal key for lesser hostile breaches. Carry it to an abyssal summoning circle to tear open a smaller pre-boss rift that disgorges abyssal imps.</description>
    <thingClass>AbyssalProtocol.Thing_AbyssalAnimatedItem</thingClass>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Things/Item/ABY_UnstableBreachSigil</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>10</stackLimit>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <statBases>
      <MarketValue>160</MarketValue>
      <Mass>0.24</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <comps>
      <li Class="CompProperties_Usable">
        <useJob>ABY_CarrySigilToCircle</useJob>
        <useLabel>open unstable breach</useLabel>
      </li>
      <li Class="AbyssalProtocol.CompProperties_UseEffectSummonBoss">
        <ritualId>unstable_breach</ritualId>
        <summonMode>ImpPortal</summonMode>
        <bossLabel>rift imp breach</bossLabel>
        <spawnPoints>160</spawnPoints>
        <ritualWarmupTicks>150</ritualWarmupTicks>
        <impCount>2</impCount>
        <impPortalWarmupTicks>90</impPortalWarmupTicks>
        <impSpawnIntervalTicks>75</impSpawnIntervalTicks>
        <impPortalLingerTicks>1800</impPortalLingerTicks>
        <completionLetterLabelKey>ABY_CircleUnstableBreachLetterLabel</completionLetterLabelKey>
        <completionLetterDescKey>ABY_CircleUnstableBreachLetterDesc</completionLetterDescKey>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="DrugBase">
    <defName>ABY_ArchonOverrideAmpoule</defName>
    <label>archon override ampoule</label>
    <description>A controlled first-boss combat stimulant. Injecting it forces a brief archon-grade surge of aim and locomotion before the captured routines burn out into a mild feedback slump.</description>
    <graphicData>
      <texPath>Things/Item/ABY_ArchonOverrideAmpoule</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>10</stackLimit>
    <tradeability>Sellable</tradeability>
    <statBases>
      <MarketValue>260</MarketValue>
      <Mass>0.12</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <ingestible>
      <foodType>Fluid, Processed</foodType>
      <baseIngestTicks>90</baseIngestTicks>
      <ingestCommandString>Inject {0}</ingestCommandString>
      <ingestReportString>Injecting {0}.</ingestReportString>
      <ingestReportStringEat>Injecting {0}.</ingestReportStringEat>
      <ingestHoldUsesTable>false</ingestHoldUsesTable>
      <useEatingSpeedStat>false</useEatingSpeedStat>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>ABY_ArchonOverrideSurge</hediffDef>
          <severity>1.0</severity>
        </li>
      </outcomeDoers>
    </ingestible>
  </ThingDef>

</Defs>
