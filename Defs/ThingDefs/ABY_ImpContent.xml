<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="AnimalThingBase">
    <defName>ABY_RiftImp</defName>
    <label>rift imp</label>
    <description>A lesser infernal predator extruded from an abyssal breach. It is smaller than the archon herald, but still fast, vicious, and unnervingly hot to the touch.</description>
    <thingClass>Pawn</thingClass>
    <category>Pawn</category>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Pawn/RiftImp/ABY_RiftImp</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1.25,1.25)</drawSize>
    </graphicData>
    <race>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>Animal</thinkTreeMain>
      <thinkTreeConstant>AnimalConstant</thinkTreeConstant>
      <hasGenders>true</hasGenders>
      <nameGenerator>NamerAnimalGenericMale</nameGenerator>
      <nameGeneratorFemale>NamerAnimalGenericFemale</nameGeneratorFemale>
      <trainability>None</trainability>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <canBecomeShambler>true</canBecomeShambler>
      <hediffGiverSets>
        <li>OrganicStandard</li>
      </hediffGiverSets>
      <body>QuadrupedAnimalWithHooves</body>
      <baseBodySize>0.72</baseBodySize>
      <baseHealthScale>1.0</baseHealthScale>
      <baseHungerRate>0.42</baseHungerRate>
      <fleshType>Normal</fleshType>
      <intelligence>Animal</intelligence>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <manhunterOnTameFailChance>0</manhunterOnTameFailChance>
      <gestationPeriodDays>8</gestationPeriodDays>
      <lifeExpectancy>90</lifeExpectancy>
      <herdAnimal>false</herdAnimal>
      <predator>true</predator>
      <foodType>CarnivoreAnimal</foodType>
      <lifeStageAges>
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
    </race>
    <statBases>
      <MaxHitPoints>300</MaxHitPoints>
      <MoveSpeed>4.6</MoveSpeed>
      <MeleeHitChance>0.78</MeleeHitChance>
      <MeleeDPS>6.8</MeleeDPS>
      <ArmorRating_Sharp>0.12</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.08</ArmorRating_Blunt>
      <ArmorRating_Heat>0.35</ArmorRating_Heat>
      <ComfyTemperatureMin>-20</ComfyTemperatureMin>
      <ComfyTemperatureMax>180</ComfyTemperatureMax>
      <Flammability>0.02</Flammability>
      <PainShockThreshold>0.88</PainShockThreshold>
      <MarketValue>420</MarketValue>
      <Mass>0.42</Mass>
    </statBases>
    <tools>
      <li>
        <label>ember claw</label>
        <capacities>
          <li>Blunt</li>
          <li>Scratch</li>
        </capacities>
        <power>8</power>
        <cooldownTime>1.65</cooldownTime>
        <chanceFactor>1.45</chanceFactor>
        <armorPenetration>0.10</armorPenetration>
      </li>
      <li>
        <label>infernal bite</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>10</power>
        <cooldownTime>2.25</cooldownTime>
        <chanceFactor>0.90</chanceFactor>
        <armorPenetration>0.14</armorPenetration>
      </li>
    </tools>
  </ThingDef>
  <ThingDef ParentName="BuildingBase">
    <defName>ABY_ImpPortal</defName>
    <label>abyssal imp portal</label>
    <description>A temporary infernal breach used by abyssal heralds to vomit lesser hunters into reality.</description>
    <thingClass>AbyssalProtocol.Building_AbyssalImpPortal</thingClass>
    <category>Building</category>
    <drawerType>RealtimeOnly</drawerType>
    <tickerType>Normal</tickerType>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <drawOffscreen>true</drawOffscreen>
    <canOverlapZones>true</canOverlapZones>
    <useHitPoints>false</useHitPoints>
    <rotatable>false</rotatable>
    <fillPercent>0.01</fillPercent>
    <passability>PassThroughOnly</passability>
    <selectable>false</selectable>
    <neverMultiSelect>true</neverMultiSelect>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <graphicData>
      <texPath>Things/VFX/ImpPortal/ABY_ImpPortal_Ring</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(3.6,3.6)</drawSize>
    </graphicData>
    <statBases>
      <MaxHitPoints>1</MaxHitPoints>
      <Mass>0.01</Mass>
    </statBases>
    <size>(1,1)</size>
  </ThingDef>
  <ThingDef ParentName="BuildingBase">
    <defName>ABY_RupturePortal</defName>
    <label>rupture portal</label>
    <description>A massive crown-rift that opens only when the beast is destroyed before its ritual cycle can complete. The true archon emerges from within.</description>
    <thingClass>AbyssalProtocol.Building_AbyssalRupturePortal</thingClass>
    <category>Building</category>
    <drawerType>RealtimeOnly</drawerType>
    <tickerType>Normal</tickerType>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <drawOffscreen>true</drawOffscreen>
    <canOverlapZones>true</canOverlapZones>
    <useHitPoints>false</useHitPoints>
    <rotatable>false</rotatable>
    <fillPercent>0.01</fillPercent>
    <passability>PassThroughOnly</passability>
    <selectable>false</selectable>
    <neverMultiSelect>true</neverMultiSelect>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <graphicData>
      <texPath>Things/VFX/RupturePortal/ABY_RupturePortal_Ring</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>MoteGlow</shaderType>
      <drawSize>(7.8,7.8)</drawSize>
    </graphicData>
    <statBases>
      <MaxHitPoints>1</MaxHitPoints>
      <Mass>0.01</Mass>
    </statBases>
    <size>(1,1)</size>
  </ThingDef>
</Defs>
