<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="AnimalThingBase">
    <defName>ABY_ChainZealot</defName>
    <label>chain zealot</label>
    <description>An infernal breach-enforcer fitted with hooked chains and restraint-limbs instead of proper doctrine hardware. Chain zealots are deployed to crash firing lines, drag ranged targets out of position, and pin open the route for the rest of the abyssal host.</description>
    <thingClass>Pawn</thingClass>
    <category>Pawn</category>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Pawn/ChainZealot/ABY_ChainZealot</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1.46,1.46)</drawSize>
    </graphicData>
    <race>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>Animal</thinkTreeMain>
      <thinkTreeConstant>AnimalConstant</thinkTreeConstant>
      <hasGenders>false</hasGenders>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <canBecomeShambler>true</canBecomeShambler>
      <hediffGiverSets>
        <li>OrganicStandard</li>
      </hediffGiverSets>
      <body>Human</body>
      <baseBodySize>0.82</baseBodySize>
      <baseHealthScale>1.18</baseHealthScale>
      <baseHungerRate>0.46</baseHungerRate>
      <fleshType>Normal</fleshType>
      <intelligence>ToolUser</intelligence>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <manhunterOnTameFailChance>0</manhunterOnTameFailChance>
      <lifeExpectancy>110</lifeExpectancy>
      <foodType>OmnivoreHuman</foodType>
      <useMeatFrom>Human</useMeatFrom>
      <gestationPeriodDays>18</gestationPeriodDays>
      <lifeStageAges Inherit="False">
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
    </race>
    <statBases>
      <MaxHitPoints>420</MaxHitPoints>
      <MoveSpeed>4.95</MoveSpeed>
      <MeleeHitChance>0.84</MeleeHitChance>
      <MeleeDPS>10.4</MeleeDPS>
      <ArmorRating_Sharp>0.22</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.16</ArmorRating_Blunt>
      <ArmorRating_Heat>0.44</ArmorRating_Heat>
      <ComfyTemperatureMin>-18</ComfyTemperatureMin>
      <ComfyTemperatureMax>180</ComfyTemperatureMax>
      <Flammability>0.02</Flammability>
      <PainShockThreshold>0.90</PainShockThreshold>
      <MarketValue>610</MarketValue>
      <Mass>0.62</Mass>
    </statBases>
    <tools>
      <li>
        <label>hooked chain</label>
        <capacities>
          <li>Blunt</li>
          <li>Scratch</li>
        </capacities>
        <power>11</power>
        <cooldownTime>1.75</cooldownTime>
        <chanceFactor>1.32</chanceFactor>
        <armorPenetration>0.15</armorPenetration>
      </li>
      <li>
        <label>breach hook</label>
        <capacities>
          <li>Blunt</li>
          <li>Stab</li>
        </capacities>
        <power>16</power>
        <cooldownTime>2.35</cooldownTime>
        <chanceFactor>0.86</chanceFactor>
        <armorPenetration>0.20</armorPenetration>
      </li>
    </tools>
    <butcherProducts>
      <ABY_AbyssalResidue>7</ABY_AbyssalResidue>
    </butcherProducts>
    <comps>
      <li Class="AbyssalProtocol.CompProperties_ChainSnag">
        <minRange>4.0</minRange>
        <maxRange>11.9</maxRange>
        <cooldownTicks>330</cooldownTicks>
        <cooldownJitterTicks>70</cooldownJitterTicks>
        <scanIntervalTicks>30</scanIntervalTicks>
        <impactHediffDefName>ABY_ChainSnared</impactHediffDefName>
      </li>
    </comps>
  </ThingDef>
</Defs>
