<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="AnimalThingBase">
    <defName>ABY_ChainZealot</defName>
    <label>chain zealot</label>
    <description>A chained fanatic forged for breach assaults and line-breaking punishment. Chain zealots lunge into firing lines, snag vulnerable shooters out of position, and pin down defenders so the abyssal host can close.</description>
    <thingClass>Pawn</thingClass>
    <category>Pawn</category>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Pawn/ChainZealot/ABY_ChainZealot</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(2.84,2.84)</drawSize>
    </graphicData>
    <race>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>Humanlike</thinkTreeMain>
      <thinkTreeConstant>HumanlikeConstant</thinkTreeConstant>
      <hasGenders>true</hasGenders>
      <nameGenerator>NamerAnimalGenericMale</nameGenerator>
      <nameGeneratorFemale>NamerAnimalGenericFemale</nameGeneratorFemale>
      <trainability>None</trainability>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <canBecomeShambler>true</canBecomeShambler>
      <hediffGiverSets>
        <li>OrganicStandard</li>
      </hediffGiverSets>
      <body>Human</body>
      <baseBodySize>1.15</baseBodySize>
      <baseHealthScale>1.75</baseHealthScale>
      <baseHungerRate>0.52</baseHungerRate>
      <fleshType>Normal</fleshType>
      <intelligence>ToolUser</intelligence>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <manhunterOnTameFailChance>0</manhunterOnTameFailChance>
      <gestationPeriodDays>18</gestationPeriodDays>
      <lifeExpectancy>110</lifeExpectancy>
      <foodType>OmnivoreHuman</foodType>
      <useMeatFrom>Human</useMeatFrom>
      <lifeStageAges Inherit="False">
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
    </race>
    <statBases>
      <MaxHitPoints>520</MaxHitPoints>
      <MoveSpeed>4.7</MoveSpeed>
      <MeleeHitChance>0.82</MeleeHitChance>
      <MeleeDPS>10.2</MeleeDPS>
      <ArmorRating_Sharp>0.24</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.18</ArmorRating_Blunt>
      <ArmorRating_Heat>0.35</ArmorRating_Heat>
      <ComfyTemperatureMin>-12</ComfyTemperatureMin>
      <ComfyTemperatureMax>170</ComfyTemperatureMax>
      <Flammability>0.03</Flammability>
      <PainShockThreshold>0.92</PainShockThreshold>
      <MarketValue>680</MarketValue>
      <Mass>0.9</Mass>
    </statBases>
    <tools>
      <li>
        <label>chain cleaver</label>
        <capacities>
          <li>Cut</li>
        </capacities>
        <power>18</power>
        <cooldownTime>1.45</cooldownTime>
        <chanceFactor>1.1</chanceFactor>
        <armorPenetration>0.24</armorPenetration>
      </li>
      <li>
        <label>hook smash</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12</power>
        <cooldownTime>2.0</cooldownTime>
        <chanceFactor>0.75</chanceFactor>
        <armorPenetration>0.16</armorPenetration>
      </li>
    </tools>
    <butcherProducts>
      <ABY_AbyssalResidue>8</ABY_AbyssalResidue>
    </butcherProducts>
    <comps>
      <li Class="AbyssalProtocol.CompProperties_AbyssalPawnController">
        <archetype>HookBruiser</archetype>
        <minimumMeleeSkill>11</minimumMeleeSkill>
      </li>
      <li Class="AbyssalProtocol.CompProperties_ChainSnag">
        <minRange>4.2</minRange>
        <maxRange>11.2</maxRange>
        <cooldownTicks>300</cooldownTicks>
        <cooldownJitterTicks>60</cooldownJitterTicks>
        <scanIntervalTicks>30</scanIntervalTicks>
        <impactHediffDefName>ABY_ChainSnared</impactHediffDefName>
      </li>
    </comps>
  </ThingDef>
</Defs>
