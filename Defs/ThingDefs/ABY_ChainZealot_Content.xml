<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="Human">
    <defName>ABY_ChainZealot</defName>
    <label>chain zealot</label>
    <description>An abyssal breach-fanatic forged for close assault. Chain zealots carry heavy infernal shields, surge through opening fire, and use chain-snare lunges to pin ranged defenders in place for the rest of the host.</description>

    <thingClass>Pawn</thingClass>
    <category>Pawn</category>
    <drawerType>RealtimeOnly</drawerType>

    <graphicData>
      <texPath>Pawn/ChainZealot/ABY_ChainZealot</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1.46,1.46)</drawSize>
    </graphicData>

    <race>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>Animal</thinkTreeMain>
      <thinkTreeConstant>AnimalConstant</thinkTreeConstant>
      <hasGenders>false</hasGenders>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <canBecomeShambler>true</canBecomeShambler>
      <hediffGiverSets>
        <li>OrganicStandard</li>
      </hediffGiverSets>
      <body>Human</body>
      <baseBodySize>0.82</baseBodySize>
      <baseHealthScale>1.20</baseHealthScale>
      <baseHungerRate>0.44</baseHungerRate>
      <fleshType>Normal</fleshType>
      <intelligence>ToolUser</intelligence>
      <nameCategory>HumanStandard</nameCategory>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <manhunterOnTameFailChance>0</manhunterOnTameFailChance>
      <lifeExpectancy>105</lifeExpectancy>
      <foodType>OmnivoreHuman</foodType>
      <useMeatFrom>Human</useMeatFrom>
      <gestationPeriodDays>18</gestationPeriodDays>
      <lifeStageAges Inherit="False">
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
    </race>

    <statBases>
      <MaxHitPoints>520</MaxHitPoints>
      <MoveSpeed>4.72</MoveSpeed>
      <MeleeHitChance>0.84</MeleeHitChance>
      <MeleeDPS>11.6</MeleeDPS>
      <ArmorRating_Sharp>0.34</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.24</ArmorRating_Blunt>
      <ArmorRating_Heat>0.62</ArmorRating_Heat>
      <ComfyTemperatureMin>-16</ComfyTemperatureMin>
      <ComfyTemperatureMax>185</ComfyTemperatureMax>
      <Flammability>0.01</Flammability>
      <PainShockThreshold>0.95</PainShockThreshold>
      <ShootingAccuracyPawn>0.70</ShootingAccuracyPawn>
      <MarketValue>760</MarketValue>
      <Mass>0.74</Mass>
    </statBases>

    <tools>
      <li>
        <label>chain cleaver</label>
        <capacities>
          <li>Cut</li>
          <li>Stab</li>
        </capacities>
        <power>17</power>
        <cooldownTime>1.55</cooldownTime>
        <chanceFactor>1.35</chanceFactor>
        <armorPenetration>0.24</armorPenetration>
      </li>
      <li>
        <label>shield bash</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>13</power>
        <cooldownTime>2.05</cooldownTime>
        <chanceFactor>1.00</chanceFactor>
        <armorPenetration>0.16</armorPenetration>
      </li>
    </tools>

    <butcherProducts>
      <ABY_AbyssalResidue>10</ABY_AbyssalResidue>
    </butcherProducts>

    <comps>
      <li Class="AbyssalProtocol.CompProperties_ChainSnag">
        <minRange>4.2</minRange>
        <maxRange>10.8</maxRange>
        <cooldownTicks>330</cooldownTicks>
        <cooldownJitterTicks>70</cooldownJitterTicks>
        <scanIntervalTicks>30</scanIntervalTicks>
        <impactHediffDefName>ABY_ChainSnared</impactHediffDefName>
      </li>
    </comps>
  </ThingDef>

</Defs>
