<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_BreachCannon</defName>
    <label>breach cannon</label>
    <description>A portable siege relic rebuilt around a raised rift-optic rail, a monolithic stock and a caged abyssal pressure heart. The breach cannon is slow, heavy and brutally deliberate: each shot hammers a stabilized rupture bolt through armor, cover and fortified targets with catastrophic force.</description>
    <techLevel>Spacer</techLevel>

    <graphicData>
      <texPath>Things/Weapon/ABY_BreachCannon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(2.15,0.72)</drawSize>
    </graphicData>

    <soundInteract>Interact_ChargeRifle</soundInteract>

    <weaponTags>
      <li>Gun</li>
      <li>RangedHeavy</li>
      <li>SpacerGun</li>
    </weaponTags>

    <recipeMaker>
      <skillRequirements>
        <Crafting>13</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
    </recipeMaker>

    <costList>
      <ABY_ReactorSaintCore>1</ABY_ReactorSaintCore>
      <ABY_AbyssalResidue>46</ABY_AbyssalResidue>
      <Plasteel>340</Plasteel>
      <Uranium>90</Uranium>
      <ComponentSpacer>9</ComponentSpacer>
    </costList>

    <statBases>
      <WorkToMake>82000</WorkToMake>
      <Mass>8.9</Mass>
      <MarketValue>6900</MarketValue>
      <AccuracyTouch>0.30</AccuracyTouch>
      <AccuracyShort>0.55</AccuracyShort>
      <AccuracyMedium>0.73</AccuracyMedium>
      <AccuracyLong>0.67</AccuracyLong>
      <RangedWeapon_Cooldown>5.05</RangedWeapon_Cooldown>
    </statBases>

    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_BreachCannonBolt</defaultProjectile>
        <warmupTime>2.85</warmupTime>
        <range>38.9</range>
        <burstShotCount>1</burstShotCount>
        <ticksBetweenBurstShots>16</ticksBetweenBurstShots>
        <soundAiming>ABY_UltraPlasmaCharge</soundAiming>
        <soundCast>Shot_ChargeRifle</soundCast>
        <muzzleFlashScale>18</muzzleFlashScale>
      </li>
    </verbs>

    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12</power>
        <cooldownTime>2.25</cooldownTime>
      </li>
      <li>
        <label>breach barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>15</power>
        <cooldownTime>2.55</cooldownTime>
        <armorPenetration>0.24</armorPenetration>
      </li>
    </tools>

    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>7000</requiredResidue>
        <category>Weapons</category>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_BreachCannonBolt</defName>
    <label>breach cannon bolt</label>
    <thingClass>Bullet</thingClass>
    <graphicData>
      <texPath>Things/Projectile/ABY_BreachCannonBolt</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.46,2.35)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>84</damageAmountBase>
      <armorPenetrationBase>1.18</armorPenetrationBase>
      <stoppingPower>4.35</stoppingPower>
      <speed>56</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>

</Defs>
