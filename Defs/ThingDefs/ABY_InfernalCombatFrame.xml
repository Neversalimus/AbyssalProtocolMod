<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="ApparelBase">
    <defName>ABY_InfernalCombatFrame</defName>
    <thingClass>Apparel</thingClass>
    <label>infernal combat frame</label>
    <description>A first-generation abyssal torso frame built as the body counterpart to the rift helm. Layered plasteel ribs, residue-lined plating and a sealed chest-core lattice make it durable enough for breach warfare without turning the wearer into dead weight.</description>
    <techLevel>Ultra</techLevel>
    <graphicData>
      <texPath>Things/Item/Apparel/ABY_InfernalCombatFrame</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.08,1.08)</drawSize>
    </graphicData>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
        <li>Neck</li>
      </bodyPartGroups>
      <layers>
        <li>Shell</li>
      </layers>
      <wornGraphicPath>Apparel/ABY_InfernalCombatFrame</wornGraphicPath>
    </apparel>
    <tradeability>Sellable</tradeability>
    <smeltable>true</smeltable>
    <equippedStatOffsets>
      <MoveSpeed>-0.03</MoveSpeed>
    </equippedStatOffsets>
    <statBases>
      <WorkToMake>3200</WorkToMake>
      <MaxHitPoints>340</MaxHitPoints>
      <Mass>4.5</Mass>
      <MarketValue>2350</MarketValue>
      <ArmorRating_Sharp>0.70</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.36</ArmorRating_Blunt>
      <ArmorRating_Heat>0.54</ArmorRating_Heat>
    </statBases>
  </ThingDef>

</Defs>
