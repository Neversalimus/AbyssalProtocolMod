      <texPath>Things/Projectile/ABY_SiegeIdolPlasmaBeam</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.40,3.10)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Burn</damageDef>
      <damageAmountBase>24</damageAmountBase>
      <armorPenetrationBase>0.88</armorPenetrationBase>
      <stoppingPower>1.75</stoppingPower>
      <speed>52</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>
</Defs>
