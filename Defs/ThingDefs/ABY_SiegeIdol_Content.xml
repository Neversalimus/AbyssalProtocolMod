<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="AnimalThingBase">
    <defName>ABY_SiegeIdol</defName>
    <label>siege idol</label>
    <description>A semi-mechanical breach idol built to follow the abyssal line rather than lead it. Siege idols advance behind the first contact wave, lock their stabilizers into the ground, and answer turrets, doors, cover, and static gunlines with furnace-bright plasma fire.</description>
    <thingClass>Pawn</thingClass>
    <category>Pawn</category>
    <drawerType>RealtimeOnly</drawerType>
    <graphicData>
      <texPath>Pawn/SiegeIdol/ABY_SiegeIdol</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(4.72,4.72)</drawSize>
    </graphicData>
    <race>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>Animal</thinkTreeMain>
      <thinkTreeConstant>AnimalConstant</thinkTreeConstant>
      <hasGenders>false</hasGenders>
      <trainability>None</trainability>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <canBecomeShambler>false</canBecomeShambler>
      <hediffGiverSets>
        <li>OrganicStandard</li>
      </hediffGiverSets>
      <body>Human</body>
      <baseBodySize>1.52</baseBodySize>
      <baseHealthScale>1.92</baseHealthScale>
      <baseHungerRate>0.52</baseHungerRate>
      <fleshType>Normal</fleshType>
      <intelligence>ToolUser</intelligence>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <manhunterOnTameFailChance>0</manhunterOnTameFailChance>
      <gestationPeriodDays>18</gestationPeriodDays>
      <lifeExpectancy>180</lifeExpectancy>
      <foodType>OmnivoreHuman</foodType>
      <useMeatFrom>Human</useMeatFrom>
      <lifeStageAges Inherit="False">
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
    </race>
    <statBases>
      <MaxHitPoints>1120</MaxHitPoints>
      <MoveSpeed>3.70</MoveSpeed>
      <MeleeHitChance>0.58</MeleeHitChance>
      <MeleeDPS>4.9</MeleeDPS>
      <MeleeDodgeChance>0.05</MeleeDodgeChance>
      <ArmorRating_Sharp>0.46</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.31</ArmorRating_Blunt>
      <ArmorRating_Heat>0.78</ArmorRating_Heat>
      <ComfyTemperatureMin>-24</ComfyTemperatureMin>
      <ComfyTemperatureMax>240</ComfyTemperatureMax>
      <Flammability>0.00</Flammability>
      <PainShockThreshold>1.14</PainShockThreshold>
      <ShootingAccuracyPawn>1.10</ShootingAccuracyPawn>
      <MarketValue>1560</MarketValue>
      <Mass>1.56</Mass>
    </statBases>
    <tools>
      <li>
        <label>stabilizer ram</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>11</power>
        <cooldownTime>2.45</cooldownTime>
        <chanceFactor>0.92</chanceFactor>
        <armorPenetration>0.12</armorPenetration>
      </li>
    </tools>
    <killedLeavings Inherit="False">
      <ABY_AbyssalResidue>16</ABY_AbyssalResidue>
    </killedLeavings>
    <comps>
      <li Class="AbyssalProtocol.CompProperties_AbyssalPawnController">
        <archetype>SiegeNode</archetype>
        <minShootingSkill>11</minShootingSkill>
        <spawnGraceTicks>48</spawnGraceTicks>
        <lordRetryTicks>60</lordRetryTicks>
        <preferredMinRange>10.8</preferredMinRange>
        <retreatSearchRadius>12</retreatSearchRadius>
        <preferRangedTargets>true</preferRangedTargets>
        <holdPositionWhenTargeting>true</holdPositionWhenTargeting>
        <targetMinRange>8.6</targetMinRange>
      </li>
      <li Class="AbyssalProtocol.CompProperties_AbyssalAutoHostile" />
      <li Class="AbyssalProtocol.CompProperties_ABY_SiegeIdolSiegeShooter">
        <projectileDefName>ABY_SiegeIdolPlasmaBolt</projectileDefName>
        <aimSoundDefName>ABY_UltraPlasmaCharge</aimSoundDefName>
        <castSoundDefName>ABY_UltraPlasmaFire</castSoundDefName>
        <breachProjectileDefName>ABY_SiegeIdolBreachShell</breachProjectileDefName>
        <breachAimSoundDefName>ABY_UltraPlasmaCharge</breachAimSoundDefName>
        <breachCastSoundDefName>ABY_UltraPlasmaFire</breachCastSoundDefName>
        <range>31.9</range>
        <warmupTicks>92</warmupTicks>
        <cooldownTicks>180</cooldownTicks>
        <scanIntervalTicks>18</scanIntervalTicks>
        <deployTicks>42</deployTicks>
        <telegraphIntervalTicks>12</telegraphIntervalTicks>
        <anchoredIdleReleaseTicks>150</anchoredIdleReleaseTicks>
        <preferredMinRange>10.8</preferredMinRange>
        <targetMinRange>8.6</targetMinRange>
        <anchorMinRange>12.4</anchorMinRange>
        <retreatSearchRadius>12</retreatSearchRadius>
        <panicMeleeRange>4.2</panicMeleeRange>
        <preferRangedTargets>true</preferRangedTargets>
        <preferBuildingTargets>true</preferBuildingTargets>
        <prioritizeTurrets>true</prioritizeTurrets>
        <prioritizeDoors>true</prioritizeDoors>
        <prioritizeCover>true</prioritizeCover>
        <breachWarmupTicks>138</breachWarmupTicks>
        <breachCooldownTicks>560</breachCooldownTicks>
        <breachTelegraphIntervalTicks>9</breachTelegraphIntervalTicks>
        <breachMinRange>15.2</breachMinRange>
        <breachRequiresBuildingTarget>true</breachRequiresBuildingTarget>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_SiegeIdolPlasmaBolt</defName>
    <label>siege plasma bolt</label>
    <graphicData>
      <texPath>Things/Projectile/ABY_SiegeIdolPlasmaBeam</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.40,3.10)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Burn</damageDef>
      <damageAmountBase>24</damageAmountBase>
      <armorPenetrationBase>0.88</armorPenetrationBase>
      <stoppingPower>1.75</stoppingPower>
      <speed>52</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_SiegeIdolBreachShell</defName>
    <label>siege breach shell</label>
    <thingClass>AbyssalProtocol.Projectile_ABY_SiegeIdolBreachShell</thingClass>
    <graphicData>
      <texPath>Things/Projectile/ABY_AshenScatterShell</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.52,0.88)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Burn</damageDef>
      <damageAmountBase>10</damageAmountBase>
      <armorPenetrationBase>0.70</armorPenetrationBase>
      <stoppingPower>0.95</stoppingPower>
      <speed>34</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>
</Defs>
