    <statBases>
      <MaxHitPoints>8600</MaxHitPoints>
      <MoveSpeed>6.25</MoveSpeed>
      <MeleeHitChance>0.98</MeleeHitChance>
      <MeleeDPS>112</MeleeDPS>
      <ArmorRating_Sharp>2.2</ArmorRating_Sharp>
      <ArmorRating_Blunt>1.85</ArmorRating_Blunt>
      <ArmorRating_Heat>2.95</ArmorRating_Heat>
      <PainShockThreshold>999</PainShockThreshold>
      <ComfyTemperatureMin>-80</ComfyTemperatureMin>
      <ComfyTemperatureMax>420</ComfyTemperatureMax>
      <Flammability>0</Flammability>
      <ToxicResistance>1</ToxicResistance>
      <PsychicSensitivity>0</PsychicSensitivity>
      <MarketValue>28000</MarketValue>
      <Mass>7.8</Mass>
    </statBases>

    <tools>
      <li>
        <label>crown talon</label>
        <capacities>
          <li>Blunt</li>
          <li>Scratch</li>
        </capacities>
        <power>92</power>
        <cooldownTime>1.5</cooldownTime>
        <chanceFactor>1.65</chanceFactor>
        <armorPenetration>0.82</armorPenetration>
      </li>
      <li>
        <label>execution limb</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>136</power>
        <cooldownTime>2.7</cooldownTime>
        <chanceFactor>1.0</chanceFactor>
        <armorPenetration>1.05</armorPenetration>
      </li>
      <li>
        <label>null maw</label>
        <capacities>
          <li>Bite</li>
          <li>Blunt</li>
        </capacities>
        <power>148</power>
        <cooldownTime>3.3</cooldownTime>
        <chanceFactor>0.8</chanceFactor>
        <armorPenetration>1.12</armorPenetration>
      </li>
    </tools>
  </ThingDef>

</Defs>
