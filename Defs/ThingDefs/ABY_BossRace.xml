<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="AnimalThingBase">
    <defName>ABY_ArchonBeast</defName>
    <label>archon beast</label>
    <description>A colossal infernal war-beast grown as the living herald of a deeper rupture. It is not the true archon, only the chained predator sent ahead of it.</description>

    <thingClass>Pawn</thingClass>
    <category>Pawn</category>
    <drawerType>RealtimeOnly</drawerType>

    <graphicData>
      <texPath>Pawn/ArchonBeast/ArchonBeast</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(3.2,3.2)</drawSize>
    </graphicData>

    <race>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>Animal</thinkTreeMain>
      <thinkTreeConstant>AnimalConstant</thinkTreeConstant>
      <hasGenders>true</hasGenders>
      <nameGenerator>NamerAnimalGenericMale</nameGenerator>
      <nameGeneratorFemale>NamerAnimalGenericFemale</nameGeneratorFemale>
      <trainability>None</trainability>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <canBecomeShambler>true</canBecomeShambler>
      <hediffGiverSets>
        <li>OrganicStandard</li>
      </hediffGiverSets>
      <body>QuadrupedAnimalWithHooves</body>
      <baseBodySize>3.2</baseBodySize>
      <baseHealthScale>4.8</baseHealthScale>
      <baseHungerRate>1.2</baseHungerRate>
      <fleshType>Normal</fleshType>
      <intelligence>Animal</intelligence>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <manhunterOnTameFailChance>0</manhunterOnTameFailChance>
      <gestationPeriodDays>12</gestationPeriodDays>
      <lifeExpectancy>400</lifeExpectancy>
      <herdAnimal>false</herdAnimal>
      <predator>true</predator>
      <foodType>CarnivoreAnimal</foodType>
      <lifeStageAges>
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
    </race>

    <statBases>
      <MaxHitPoints>2250</MaxHitPoints>
      <MoveSpeed>5.2</MoveSpeed>
      <MeleeHitChance>0.92</MeleeHitChance>
      <MeleeDPS>38</MeleeDPS>
      <ArmorRating_Sharp>1.1</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.95</ArmorRating_Blunt>
      <ArmorRating_Heat>1.4</ArmorRating_Heat>
      <PainShockThreshold>999</PainShockThreshold>
      <ComfyTemperatureMin>-40</ComfyTemperatureMin>
      <ComfyTemperatureMax>220</ComfyTemperatureMax>
      <Flammability>0</Flammability>
      <ToxicResistance>1</ToxicResistance>
      <PsychicSensitivity>0</PsychicSensitivity>
      <MarketValue>6000</MarketValue>
      <Mass>4.5</Mass>
    </statBases>

    <tools>
      <li>
        <label>infernal claw</label>
        <capacities>
          <li>Blunt</li>
          <li>Scratch</li>
        </capacities>
        <power>42</power>
        <cooldownTime>1.8</cooldownTime>
        <chanceFactor>1.4</chanceFactor>
        <armorPenetration>0.38</armorPenetration>
      </li>
      <li>
        <label>maw</label>
        <capacities>
          <li>Bite</li>
          <li>Blunt</li>
        </capacities>
        <power>52</power>
        <cooldownTime>2.6</cooldownTime>
        <chanceFactor>0.9</chanceFactor>
        <armorPenetration>0.44</armorPenetration>
      </li>
      <li>
        <label>crushing forelimb</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>65</power>
        <cooldownTime>3.4</cooldownTime>
        <chanceFactor>0.65</chanceFactor>
        <armorPenetration>0.5</armorPenetration>
      </li>
    </tools>

    <killedLeavings Inherit="False">
      <ABY_ArchonOverrideAmpoule>1</ABY_ArchonOverrideAmpoule>
    </killedLeavings>
  </ThingDef>

  <ThingDef ParentName="AnimalThingBase">
    <defName>ABY_ArchonOfRupture</defName>
    <label>archon of rupture</label>
    <description>The true archon hidden behind the beast. A crown-limbed infernal executor that only manifests when the herald is annihilated before it can unfold its ritual phases.</description>

    <thingClass>Pawn</thingClass>
    <category>Pawn</category>
    <drawerType>RealtimeOnly</drawerType>

    <graphicData>
      <texPath>Pawn/ArchonOfRupture/ArchonOfRupture</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(4.6,4.6)</drawSize>
    </graphicData>

    <race>
      <renderTree>Animal</renderTree>
      <thinkTreeMain>Animal</thinkTreeMain>
      <thinkTreeConstant>AnimalConstant</thinkTreeConstant>
      <hasGenders>false</hasGenders>
      <trainability>None</trainability>
      <bloodDef>Filth_Blood</bloodDef>
      <bloodSmearDef>Filth_BloodSmear</bloodSmearDef>
      <canBecomeShambler>false</canBecomeShambler>
      <hediffGiverSets>
        <li>OrganicStandard</li>
      </hediffGiverSets>
      <body>QuadrupedAnimalWithHooves</body>
      <baseBodySize>4.8</baseBodySize>
      <baseHealthScale>8.6</baseHealthScale>
      <baseHungerRate>0.85</baseHungerRate>
      <fleshType>Normal</fleshType>
      <intelligence>Animal</intelligence>
      <manhunterOnDamageChance>0</manhunterOnDamageChance>
      <manhunterOnTameFailChance>0</manhunterOnTameFailChance>
      <gestationPeriodDays>18</gestationPeriodDays>
      <lifeExpectancy>1000</lifeExpectancy>
      <herdAnimal>false</herdAnimal>
      <predator>true</predator>
      <foodType>CarnivoreAnimal</foodType>
      <lifeStageAges>
        <li>
          <def>AnimalAdult</def>
          <minAge>0</minAge>
        </li>
      </lifeStageAges>
