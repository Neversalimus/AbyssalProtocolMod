<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_AshenPike</defName>
    <label>ashen pike</label>
    <description>A disciplined anti-armor pike-gun forged around an ashen core. Instead of venting energy like a breach rifle, it drives a furnace-bound spike through the barrel and hammers a single infernal shot into the target line.</description>
    <techLevel>Spacer</techLevel>

    <graphicData>
      <texPath>Things/Weapon/ABY_AshenPike</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <soundInteract>Interact_ChargeRifle</soundInteract>

    <weaponTags>
      <li>Gun</li>
      <li>RangedHeavy</li>
    </weaponTags>

    <recipeMaker>
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
    </recipeMaker>

    <costList>
      <ABY_AshenCore>1</ABY_AshenCore>
      <ABY_AbyssalResidue>14</ABY_AbyssalResidue>
      <Steel>40</Steel>
      <Plasteel>24</Plasteel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>

    <statBases>
      <WorkToMake>26000</WorkToMake>
      <Mass>4.3</Mass>
      <MarketValue>2150</MarketValue>
      <AccuracyTouch>0.87</AccuracyTouch>
      <AccuracyShort>0.84</AccuracyShort>
      <AccuracyMedium>0.73</AccuracyMedium>
      <AccuracyLong>0.52</AccuracyLong>
      <RangedWeapon_Cooldown>2.35</RangedWeapon_Cooldown>
    </statBases>

    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_AshenPikeSpike</defaultProjectile>
        <warmupTime>1.35</warmupTime>
        <range>29.9</range>
        <burstShotCount>1</burstShotCount>
        <ticksBetweenBurstShots>10</ticksBetweenBurstShots>
        <soundCast>ABY_AshenPikeFire</soundCast>
        <muzzleFlashScale>12</muzzleFlashScale>
      </li>
    </verbs>

    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>11</power>
        <cooldownTime>2.1</cooldownTime>
      </li>
      <li>
        <label>pike muzzle</label>
        <capacities>
          <li>Poke</li>
        </capacities>
        <power>13</power>
        <cooldownTime>2.2</cooldownTime>
        <armorPenetration>0.22</armorPenetration>
      </li>
    </tools>

    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>185</requiredResidue>
        <category>Weapons</category>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_AshenPikeSpike</defName>
    <label>ashen pike spike</label>
    <thingClass>AbyssalProtocol.Projectile_AshenPikeSpike</thingClass>
    <graphicData>
      <texPath>Things/Projectile/ABY_AshenPikeSpike</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.18,0.78)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Bullet</damageDef>
      <damageAmountBase>34</damageAmountBase>
      <armorPenetrationBase>0.52</armorPenetrationBase>
      <stoppingPower>2.35</stoppingPower>
      <speed>68</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>

</Defs>
