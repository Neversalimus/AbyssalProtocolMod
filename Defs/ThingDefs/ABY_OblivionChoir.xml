<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>ABY_OblivionChoir</defName>
    <label>oblivion choir</label>
    <description>A forge-born annihilation cannon that chambers choir cells into a constrained abyssal core. The projectile advances like a miniature breach-heart, lashing nearby targets on its way in before detonating in a violent infernal bloom. It is brutally effective against clustered infantry, breach points and static defenses, but it is slow, heavy and ruinously expensive to feed.</description>
    <techLevel>Spacer</techLevel>

    <graphicData>
      <texPath>Things/Item/Equipment/WeaponRanged/ABY_OblivionChoir</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>

    <soundInteract>Interact_ChargeRifle</soundInteract>

    <statBases>
      <WorkToMake>160000</WorkToMake>
      <Mass>11.8</Mass>
      <AccuracyTouch>0.42</AccuracyTouch>
      <AccuracyShort>0.61</AccuracyShort>
      <AccuracyMedium>0.66</AccuracyMedium>
      <AccuracyLong>0.60</AccuracyLong>
      <RangedWeapon_Cooldown>4.80</RangedWeapon_Cooldown>
    </statBases>

    <recipeMaker>
      <skillRequirements>
        <Crafting>13</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>ABY_AbyssalForge</li>
      </recipeUsers>
    </recipeMaker>

    <costList>
      <ABY_AbyssalResidue>180</ABY_AbyssalResidue>
      <Plasteel>160</Plasteel>
      <Steel>240</Steel>
      <Uranium>60</Uranium>
      <ComponentIndustrial>8</ComponentIndustrial>
      <ComponentSpacer>4</ComponentSpacer>
    </costList>

    <weaponTags>
      <li>SpacerGun</li>
    </weaponTags>

    <verbs>
      <li>
        <verbClass>AbyssalProtocol.Verb_ShootAbyssalReloadable</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>ABY_OblivionChoirCoreProjectile</defaultProjectile>
        <warmupTime>2.80</warmupTime>
        <range>35.9</range>
        <ticksBetweenBurstShots>1</ticksBetweenBurstShots>
        <burstShotCount>1</burstShotCount>
        <soundAiming>ABY_UltraPlasmaCharge</soundAiming>
        <soundCast>ABY_UltraPlasmaFire</soundCast>
        <soundCastTail>ABY_UltraPlasmaTail</soundCastTail>
        <muzzleFlashScale>14</muzzleFlashScale>
      </li>
    </verbs>

    <tools>
      <li>
        <label>housing</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>11</power>
        <cooldownTime>2.2</cooldownTime>
      </li>
      <li>
        <label>reactor ring</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>13</power>
        <cooldownTime>2.2</cooldownTime>
      </li>
    </tools>

    <comps>
      <li Class="AbyssalProtocol.CompProperties_AbyssalReloadable">
        <maxCharges>4</maxCharges>
        <ammoDef>ABY_OblivionChoirCell</ammoDef>
        <ammoCountPerCharge>1</ammoCountPerCharge>
        <ammoCountToRefill>4</ammoCountToRefill>
        <baseReloadTicks>240</baseReloadTicks>
        <verbToUse>0</verbToUse>
        <displayGizmoWhileUndrafted>false</displayGizmoWhileUndrafted>
        <chargeNoun>choir cell</chargeNoun>
        <destroyOnEmpty>false</destroyOnEmpty>
        <soundReload>ABY_UltraPlasmaCharge</soundReload>
      </li>
    </comps>

    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>600</requiredResidue>
        <category>Weapons</category>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>ABY_OblivionChoirCell</defName>
    <label>choir cell</label>
    <description>A sealed infernal magazine cell for the Oblivion Choir. Each charge contains a stabilized choir-core seed that unravels into a breach-like plasma heart once fired.</description>
    <graphicData>
      <texPath>Things/Item/ABY_OblivionChoirCell</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeability>Sellable</tradeability>
    <stackLimit>20</stackLimit>
    <statBases>
      <MarketValue>90</MarketValue>
      <Mass>0.18</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalForgeUnlock">
        <requiredResidue>600</requiredResidue>
        <category>Weapons</category>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>ABY_OblivionChoirCoreProjectile</defName>
    <label>oblivion core</label>
    <thingClass>AbyssalProtocol.Projectile_OblivionChoirCore</thingClass>
    <graphicData>
      <texPath>Things/Projectile/ABY_OblivionChoirCore</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.90,0.82)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Burn</damageDef>
      <damageAmountBase>38</damageAmountBase>
      <armorPenetrationBase>1.05</armorPenetrationBase>
      <stoppingPower>4.2</stoppingPower>
      <speed>18</speed>
      <soundImpactAnticipate>BulletImpact_Ground</soundImpactAnticipate>
    </projectile>
  </ThingDef>

</Defs>
