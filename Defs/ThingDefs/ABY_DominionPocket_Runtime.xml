<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>ABY_DominionPocketExit</defName>
    <label>dominion extraction gate</label>
    <description>A temporary extraction anchor formed inside the dominion slice. It is not the final version of the encounter, but it allows a strike team to return to the colony during runtime testing.</description>
    <thingClass>AbyssalProtocol.Building_ABY_DominionPocketExit</thingClass>
    <category>Building</category>
    <drawerType>MapMeshAndRealTime</drawerType>
    <tickerType>Normal</tickerType>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <fillPercent>0.18</fillPercent>
    <rotatable>false</rotatable>
    <selectable>true</selectable>
    <useHitPoints>true</useHitPoints>
    <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
    <canOverlapZones>true</canOverlapZones>
    <graphicData>
      <texPath>Things/Building/DominionGate/ABY_DominionGate_Ring_Frame0</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(4.8,4.8)</drawSize>
    </graphicData>
    <statBases>
      <MaxHitPoints>9999</MaxHitPoints>
      <Mass>10</Mass>
      <Flammability>0</Flammability>
    </statBases>
    <size>(3,3)</size>
    <thingCategories Inherit="False" />
  </ThingDef>

</Defs>
