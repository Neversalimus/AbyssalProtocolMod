<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!--
    Future-only manifestation profiles.
    These are intentionally disabled by default and are not referenced by current summon content.
    They exist only as a ready matrix layer for later hookup.
  -->

  <ABY_ArrivalManifestationProfileDef>
    <defName>ABY_ManifestationProfile_PostBossCommon</defName>
    <label>future post-boss common manifestation profile</label>
    <description>Disabled-by-default future matrix profile for common post-boss hostile arrivals.</description>
    <enabledByDefault>false</enabledByDefault>
    <defaultWarmupTicks>110</defaultWarmupTicks>
    <requiredFeatureFlag>ABY_EnableFutureManifestationMatrix</requiredFeatureFlag>
    <options>
      <li>
        <type>SigilBloom</type>
        <weight>40</weight>
        <warmupTicksOverride>110</warmupTicksOverride>
        <enabledByDefault>false</enabledByDefault>
        <requiredFeatureFlag>ABY_EnableSigilBloomFutureMatrix</requiredFeatureFlag>
      </li>
      <li>
        <type>StaticPhaseIn</type>
        <weight>20</weight>
        <warmupTicksOverride>95</warmupTicksOverride>
        <enabledByDefault>false</enabledByDefault>
        <requiredFeatureFlag>ABY_EnableStaticPhaseInFutureMatrix</requiredFeatureFlag>
      </li>
      <li>
        <type>SeamBreach</type>
        <weight>10</weight>
        <warmupTicksOverride>80</warmupTicksOverride>
        <enabledByDefault>false</enabledByDefault>
        <requiredFeatureFlag>ABY_EnableSeamBreachFutureMatrix</requiredFeatureFlag>
      </li>
    </options>
  </ABY_ArrivalManifestationProfileDef>

