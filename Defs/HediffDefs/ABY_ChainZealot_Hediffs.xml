<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>ABY_ChainSnared</defName>
    <label>chain snared</label>
    <description>A barbed chain lash has locked muscles and balance just long enough to ruin repositioning and open the target to a breach rush.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.95, 0.20, 0.10)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>300</disappearsAfterTicks>
      </li>
    </comps>
    <stages>
      <li>
        <minSeverity>0.01</minSeverity>
        <statOffsets>
          <MoveSpeed>-0.22</MoveSpeed>
          <MeleeHitChance>-0.04</MeleeHitChance>
          <ShootingAccuracyPawn>-0.06</ShootingAccuracyPawn>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
