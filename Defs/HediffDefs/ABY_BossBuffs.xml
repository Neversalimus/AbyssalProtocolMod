<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>ABY_ArchonCore</defName>
    <label>archon core</label>
    <description>A bound reactor-heart pumping infernal energy through the beast. As the beast weakens, the core destabilizes and floods the battlefield with heat.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>

    <comps>
      <li Class="AbyssalProtocol.HediffCompProperties_ArchonCoreController">
        <phase2HealthPct>0.70</phase2HealthPct>
        <phase3HealthPct>0.35</phase3HealthPct>

        <phase1AuraRadius>6.0</phase1AuraRadius>
        <phase2AuraRadius>7.0</phase2AuraRadius>
        <phase3AuraRadius>8.0</phase3AuraRadius>

        <phase1HeatstrokeSeverity>0.0035</phase1HeatstrokeSeverity>
        <phase2HeatstrokeSeverity>0.0060</phase2HeatstrokeSeverity>
        <phase3HeatstrokeSeverity>0.0090</phase3HeatstrokeSeverity>

        <auraIntervalTicks>60</auraIntervalTicks>
      </li>
    </comps>

    <stages>
      <li>
        <minSeverity>0.0</minSeverity>
        <label>archon core - phase 1</label>
        <statOffsets>
          <MoveSpeed>0.45</MoveSpeed>
          <MeleeHitChance>0.18</MeleeHitChance>
          <ArmorRating_Heat>0.35</ArmorRating_Heat>
        </statOffsets>
      </li>

      <li>
        <minSeverity>1.0</minSeverity>
        <label>archon core - phase 2</label>
        <statOffsets>
          <MoveSpeed>0.60</MoveSpeed>
          <MeleeHitChance>0.24</MeleeHitChance>
          <ArmorRating_Heat>0.50</ArmorRating_Heat>
        </statOffsets>
      </li>

      <li>
        <minSeverity>2.0</minSeverity>
        <label>archon core - phase 3</label>
        <statOffsets>
          <MoveSpeed>0.85</MoveSpeed>
          <MeleeHitChance>0.32</MeleeHitChance>
          <ArmorRating_Heat>0.70</ArmorRating_Heat>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>ABY_ArchonCarapace</defName>
    <label>archon carapace</label>
    <description>Layered abyssal plates that absorb impact and heat.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>

    <stages>
      <li>
        <statOffsets>
          <ArmorRating_Sharp>0.45</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.35</ArmorRating_Blunt>
          <ArmorRating_Heat>0.25</ArmorRating_Heat>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
