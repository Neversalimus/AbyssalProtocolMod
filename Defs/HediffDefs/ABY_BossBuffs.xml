<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>ABY_ArchonCore</defName>
    <label>archon core</label>
    <description>A bound reactor-heart pumping infernal energy through the beast. As the beast weakens, the core destabilizes and floods the battlefield with heat.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>

    <comps>
      <li Class="AbyssalProtocol.HediffCompProperties_ArchonCoreController">
        <phase2HealthPct>0.70</phase2HealthPct>
        <phase3HealthPct>0.35</phase3HealthPct>

        <phase1AuraRadius>6.0</phase1AuraRadius>
        <phase2AuraRadius>7.0</phase2AuraRadius>
        <phase3AuraRadius>8.0</phase3AuraRadius>

        <phase1HeatstrokeSeverity>0.0035</phase1HeatstrokeSeverity>
        <phase2HeatstrokeSeverity>0.0060</phase2HeatstrokeSeverity>
        <phase3HeatstrokeSeverity>0.0090</phase3HeatstrokeSeverity>

        <auraIntervalTicks>60</auraIntervalTicks>

        <dashPhase>3</dashPhase>
        <dashCooldownTicks>780</dashCooldownTicks>
        <dashSearchIntervalTicks>30</dashSearchIntervalTicks>
        <dashMinRange>7.0</dashMinRange>
        <dashMaxRange>24.0</dashMaxRange>
        <dashLandingRadius>1.9</dashLandingRadius>

        <bloodStabilizeIntervalTicks>30</bloodStabilizeIntervalTicks>
        <bloodLossReductionPerPulse>0.025</bloodLossReductionPerPulse>
        <heatstrokeReductionPerPulse>0.020</heatstrokeReductionPerPulse>

        <downedRecoveryIntervalTicks>15</downedRecoveryIntervalTicks>
        <emergencyBloodLossClamp>0.12</emergencyBloodLossClamp>
        <emergencyHeatstrokeClamp>0.10</emergencyHeatstrokeClamp>
        <emergencyHealInjurySeverity>0.35</emergencyHealInjurySeverity>

        <dashInfernalRadius>1.5</dashInfernalRadius>
        <dashInfernalFireChance>0.22</dashInfernalFireChance>
        <dashInfernalAshCountDeparture>2</dashInfernalAshCountDeparture>
        <dashInfernalAshCountArrival>3</dashInfernalAshCountArrival>

        <phase2PortalEventDurationTicks>900</phase2PortalEventDurationTicks>
        <phase2PortalWarmupTicks>42</phase2PortalWarmupTicks>
        <phase2PortalImpSpawnIntervalTicks>18</phase2PortalImpSpawnIntervalTicks>
        <phase2PortalLingerTicks>180</phase2PortalLingerTicks>
        <phase2PortalImpsPerColonist>3</phase2PortalImpsPerColonist>
        <phase2PortalMaxImpsPerPortal>3</phase2PortalMaxImpsPerPortal>
        <phase2RetreatMaintainIntervalTicks>45</phase2RetreatMaintainIntervalTicks>
      </li>
    </comps>

    <stages>
      <li>
        <minSeverity>0.0</minSeverity>
        <label>archon core - phase 1</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.60</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>0.80</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>0.30</offset>
          </li>
        </capMods>
        <statOffsets>
          <MoveSpeed>0.45</MoveSpeed>
          <MeleeHitChance>0.18</MeleeHitChance>
          <ArmorRating_Heat>0.35</ArmorRating_Heat>
          <PainShockThreshold>999</PainShockThreshold>
        </statOffsets>
      </li>

      <li>
        <minSeverity>1.0</minSeverity>
        <label>archon core - phase 2</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.90</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>1.10</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>0.45</offset>
          </li>
        </capMods>
        <statOffsets>
          <MoveSpeed>0.60</MoveSpeed>
          <MeleeHitChance>0.24</MeleeHitChance>
          <ArmorRating_Heat>0.50</ArmorRating_Heat>
          <PainShockThreshold>999</PainShockThreshold>
        </statOffsets>
      </li>

      <li>
        <minSeverity>2.0</minSeverity>
        <label>archon core - phase 3</label>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>1.20</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>1.35</offset>
          </li>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>0.60</offset>
          </li>
        </capMods>
        <statOffsets>
          <MoveSpeed>0.85</MoveSpeed>
          <MeleeHitChance>0.32</MeleeHitChance>
          <ArmorRating_Heat>0.70</ArmorRating_Heat>
          <PainShockThreshold>999</PainShockThreshold>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>ABY_ArchonCarapace</defName>
    <label>archon carapace</label>
    <description>Layered abyssal plates that absorb impact and heat.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>

    <stages>
      <li>
        <statOffsets>
          <ArmorRating_Sharp>0.45</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.35</ArmorRating_Blunt>
          <ArmorRating_Heat>0.25</ArmorRating_Heat>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
