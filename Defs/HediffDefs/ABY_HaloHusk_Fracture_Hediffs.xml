<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef>
    <defName>ABY_HaloFractureDazzled</defName>
    <label>halo fracture flash</label>
    <description>The collapsing halo shell leaves a harsh residual glare that briefly disrupts aim and visual focus.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <tendable>false</tendable>
    <stages>
      <li>
        <statOffsets>
          <ShootingAccuracyPawn>-0.12</ShootingAccuracyPawn>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>240</disappearsAfterTicks>
      </li>
    </comps>
  </HediffDef>

</Defs>
