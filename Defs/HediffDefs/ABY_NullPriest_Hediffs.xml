<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>ABY_NullPriestWard</defName>
    <label>null ward</label>
    <description>Null-lit rite bands tighten the local breach line. Nearby abyssal bodies move with unsettling calm and their outer layers momentarily hold against return fire.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.20, 0.95, 1.00)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>120</disappearsAfterTicks>
      </li>
    </comps>
    <stages>
      <li>
        <minSeverity>0.01</minSeverity>
        <statOffsets>
          <MoveSpeed>0.06</MoveSpeed>
          <ArmorRating_Sharp>0.04</ArmorRating_Sharp>
          <ArmorRating_Heat>0.05</ArmorRating_Heat>
          <MeleeDodgeChance>0.02</MeleeDodgeChance>
          <ShootingAccuracyPawn>0.02</ShootingAccuracyPawn>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.55</minSeverity>
        <statOffsets>
          <MoveSpeed>0.10</MoveSpeed>
          <ArmorRating_Sharp>0.08</ArmorRating_Sharp>
          <ArmorRating_Heat>0.10</ArmorRating_Heat>
          <MeleeDodgeChance>0.06</MeleeDodgeChance>
          <ShootingAccuracyPawn>0.05</ShootingAccuracyPawn>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>ABY_NullExposure</defName>
    <label>null exposure</label>
    <description>Null-pressure has spread across the target's armor seams and timing instincts. Defensive layers separate, heat protection unravels, and close combat reactions briefly lose their edge.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.34, 1.00, 1.00)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>360</disappearsAfterTicks>
      </li>
    </comps>
    <stages>
      <li>
        <minSeverity>0.01</minSeverity>
        <label>thinned</label>
        <statOffsets>
          <ArmorRating_Sharp>-0.06</ArmorRating_Sharp>
          <ArmorRating_Blunt>-0.03</ArmorRating_Blunt>
          <ArmorRating_Heat>-0.08</ArmorRating_Heat>
          <MeleeDodgeChance>-0.02</MeleeDodgeChance>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.70</minSeverity>
        <label>unbound</label>
        <statOffsets>
          <ArmorRating_Sharp>-0.14</ArmorRating_Sharp>
          <ArmorRating_Blunt>-0.08</ArmorRating_Blunt>
          <ArmorRating_Heat>-0.18</ArmorRating_Heat>
          <MeleeDodgeChance>-0.05</MeleeDodgeChance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>
</Defs>
