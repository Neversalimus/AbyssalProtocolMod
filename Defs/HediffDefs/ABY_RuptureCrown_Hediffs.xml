<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>ABY_RuptureCrownBearer</defName>
    <label>rupture crown bond</label>
    <description>The crown is bonded to this pawn.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <scenarioCanAdd>false</scenarioCanAdd>
    <isBad>false</isBad>
    <comps>
      <li Class="Verse.HediffCompProperties_GiveAbility">
        <abilityDef>ABY_RuptureSentence</abilityDef>
      </li>
    </comps>
  </HediffDef>

  <HediffDef>
    <defName>ABY_RuptureSentenceMark</defName>
    <label>rupture sentence</label>
    <description>The hidden archon's verdict collapses motion, prediction and armor harmonics. For a long time the target is slower, easier to pin and far more vulnerable to focused fire.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <showRemainingTime>true</showRemainingTime>
        <disappearsAfterTicks>4320</disappearsAfterTicks>
      </li>
      <li Class="HediffCompProperties_DisappearsOnDeath" />
    </comps>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>-0.35</MoveSpeed>
          <MeleeHitChance>-0.20</MeleeHitChance>
          <MeleeDodgeChance>-0.12</MeleeDodgeChance>
          <ShootingAccuracyPawn>-0.15</ShootingAccuracyPawn>
          <ArmorRating_Sharp>-0.25</ArmorRating_Sharp>
          <ArmorRating_Blunt>-0.25</ArmorRating_Blunt>
          <ArmorRating_Heat>-0.25</ArmorRating_Heat>
        </statOffsets>
        <statFactors>
          <AimingDelayFactor>1.20</AimingDelayFactor>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

</Defs>
