<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef ParentName="ImplantHediffBase">
    <defName>ABY_CanticleSubcoreNode_Implant</defName>
    <label>canticle subcore node</label>
    <description>An auxiliary choir subcore seated beside the brain, granting a second line of ordered cognition without replacing the host mind outright.</description>
    <spawnThingOnRemoved>ABY_CanticleSubcoreNode</spawnThingOnRemoved>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.08</offset>
          </li>
        </capMods>
        <statOffsets>
          <ResearchSpeed>0.10</ResearchSpeed>
          <GlobalLearningFactor>0.08</GlobalLearningFactor>
          <AimingDelayFactor>-0.03</AimingDelayFactor>
        </statOffsets>
        <statFactors>
          <RestFallRateFactor>1.05</RestFallRateFactor>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="AddedBodyPartBase">
    <defName>ABY_ResonanceServoArm_Implant</defName>
    <label>resonance servo arm</label>
    <description>A choir-pattern servo arm tuned for cleaner weapon handling, measured aim discipline and stable manipulation.</description>
    <hediffClass>Hediff_AddedPart</hediffClass>
    <addedPartProps>
      <solid>true</solid>
      <betterThanNatural>true</betterThanNatural>
      <partEfficiency>1.10</partEfficiency>
    </addedPartProps>
    <spawnThingOnRemoved>ABY_ResonanceServoArm</spawnThingOnRemoved>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Manipulation</capacity>
            <offset>0.10</offset>
          </li>
        </capMods>
        <statOffsets>
          <ShootingAccuracyPawn>0.03</ShootingAccuracyPawn>
          <AimingDelayFactor>-0.04</AimingDelayFactor>
          <MeleeHitChance>0.01</MeleeHitChance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="ImplantHediffBase">
    <defName>ABY_HarmonicMesh_Implant</defName>
    <label>harmonic mesh</label>
    <description>A subdermal choir weave that spreads impact and heat through a disciplined resonance lattice.</description>
    <spawnThingOnRemoved>ABY_HarmonicMesh</spawnThingOnRemoved>
    <tags>
      <li>ArmorGland</li>
    </tags>
    <stages>
      <li>
        <statOffsets>
          <ArmorRating_Sharp>0.12</ArmorRating_Sharp>
          <ArmorRating_Blunt>0.08</ArmorRating_Blunt>
          <ArmorRating_Heat>0.14</ArmorRating_Heat>
          <PawnBeauty>-0.20</PawnBeauty>
          <MoveSpeed>-0.01</MoveSpeed>
        </statOffsets>
        <totalBleedFactor>0.93</totalBleedFactor>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="AddedBodyPartBase">
    <defName>ABY_ChoirSinkKidney_Implant</defName>
    <label>choir sink kidney</label>
    <description>A resonance-cooled renal sink that filters harder and vents hostile thermal pressure away from the body.</description>
    <hediffClass>Hediff_AddedPart</hediffClass>
    <addedPartProps>
      <solid>true</solid>
      <betterThanNatural>true</betterThanNatural>
      <partEfficiency>1.12</partEfficiency>
    </addedPartProps>
    <spawnThingOnRemoved>ABY_ChoirSinkKidney</spawnThingOnRemoved>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>BloodFiltration</capacity>
            <offset>0.22</offset>
          </li>
        </capMods>
        <statOffsets>
          <ImmunityGainSpeed>0.08</ImmunityGainSpeed>
          <ArmorRating_Heat>0.10</ArmorRating_Heat>
          <PainShockThreshold>0.02</PainShockThreshold>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
