<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>ABY_EmberShock</defName>
    <label>ember shock</label>
    <description>An ember hound impact overloads motion and aim for a brief moment, leaving muscles shaking and line discipline broken.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.95, 0.36, 0.12)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>240</disappearsAfterTicks>
      </li>
    </comps>
    <stages>
      <li>
        <minSeverity>0.01</minSeverity>
        <statOffsets>
          <MoveSpeed>-0.35</MoveSpeed>
          <MeleeHitChance>-0.05</MeleeHitChance>
          <ShootingAccuracyPawn>-0.08</ShootingAccuracyPawn>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
