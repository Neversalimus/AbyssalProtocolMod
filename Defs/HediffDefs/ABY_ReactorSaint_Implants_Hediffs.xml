<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef ParentName="AddedBodyPartBase">
    <defName>ABY_SaintReactorHeart_Implant</defName>
    <label>saint reactor heart</label>
    <description>A saint-class reactor heart that stabilizes combat rhythm, consciousness, and thermal endurance.</description>
    <hediffClass>Hediff_AddedPart</hediffClass>
    <addedPartProps>
      <solid>true</solid>
      <betterThanNatural>true</betterThanNatural>
      <partEfficiency>1.20</partEfficiency>
    </addedPartProps>
    <spawnThingOnRemoved>ABY_SaintReactorHeart</spawnThingOnRemoved>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>BloodPumping</capacity>
            <offset>0.32</offset>
          </li>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.07</offset>
          </li>
        </capMods>
        <statOffsets>
          <MoveSpeed>0.04</MoveSpeed>
          <PainShockThreshold>0.10</PainShockThreshold>
          <ArmorRating_Heat>0.10</ArmorRating_Heat>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="AddedBodyPartBase">
    <defName>ABY_AegisSinkKidney_Implant</defName>
    <label>aegis sink kidney</label>
    <description>A saint-tier renal heat sink that filters harder and vents reactor pressure away from the body.</description>
    <hediffClass>Hediff_AddedPart</hediffClass>
    <addedPartProps>
      <solid>true</solid>
      <betterThanNatural>true</betterThanNatural>
      <partEfficiency>1.22</partEfficiency>
    </addedPartProps>
    <spawnThingOnRemoved>ABY_AegisSinkKidney</spawnThingOnRemoved>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>BloodFiltration</capacity>
            <offset>0.32</offset>
          </li>
        </capMods>
        <statOffsets>
          <ImmunityGainSpeed>0.14</ImmunityGainSpeed>
          <ArmorRating_Heat>0.22</ArmorRating_Heat>
          <PainShockThreshold>0.05</PainShockThreshold>
        </statOffsets>
        <totalBleedFactor>0.86</totalBleedFactor>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="AddedBodyPartBase">
    <defName>ABY_VesperServoArm_Implant</defName>
    <label>vesper servo arm</label>
    <description>An execution-grade saint armature tuned for manipulation, aim discipline, and decisive ranged handling.</description>
    <hediffClass>Hediff_AddedPart</hediffClass>
    <addedPartProps>
      <solid>true</solid>
      <betterThanNatural>true</betterThanNatural>
      <partEfficiency>1.18</partEfficiency>
    </addedPartProps>
    <spawnThingOnRemoved>ABY_VesperServoArm</spawnThingOnRemoved>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Manipulation</capacity>
            <offset>0.14</offset>
          </li>
        </capMods>
        <statOffsets>
          <ShootingAccuracyPawn>0.06</ShootingAccuracyPawn>
          <AimingDelayFactor>-0.08</AimingDelayFactor>
          <MeleeHitChance>0.02</MeleeHitChance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef ParentName="ImplantHediffBase">
    <defName>ABY_HaloSubcoreNode_Implant</defName>
    <label>halo subcore node</label>
    <description>An auxiliary halo subcore seated beside the brain rather than in place of it, granting a second line of ordered cognition.</description>
    <spawnThingOnRemoved>ABY_HaloSubcoreNode</spawnThingOnRemoved>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.10</offset>
          </li>
        </capMods>
        <statOffsets>
          <ResearchSpeed>0.20</ResearchSpeed>
          <GlobalLearningFactor>0.10</GlobalLearningFactor>
          <AimingDelayFactor>-0.05</AimingDelayFactor>
        </statOffsets>
        <statFactors>
          <RestFallRateFactor>1.07</RestFallRateFactor>
        </statFactors>
      </li>
    </stages>
  </HediffDef>

</Defs>
