<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>ABY_ChoirEngineUplift</defName>
    <label>choir uplift</label>
    <description>Infernal relay harmonics tighten motion, sharpen firing rhythm, and harden nearby abyssal bodies into a more disciplined breach line.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(1.00, 0.36, 0.18)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>120</disappearsAfterTicks>
      </li>
    </comps>
    <stages>
      <li>
        <minSeverity>0.01</minSeverity>
        <statOffsets>
          <MoveSpeed>0.10</MoveSpeed>
          <ShootingAccuracyPawn>0.05</ShootingAccuracyPawn>
          <MeleeHitChance>0.04</MeleeHitChance>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.65</minSeverity>
        <statOffsets>
          <MoveSpeed>0.16</MoveSpeed>
          <ShootingAccuracyPawn>0.09</ShootingAccuracyPawn>
          <MeleeHitChance>0.07</MeleeHitChance>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>ABY_ChoirSignalNoise</defName>
    <label>signal noise</label>
    <description>Command-static from a Choir Engine is bleeding through local sightlines, targeting cues, and motor timing. Defenders lose precision as the infernal relay floods the battlefield.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(1.00, 0.22, 0.12)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>120</disappearsAfterTicks>
      </li>
    </comps>
    <stages>
      <li>
        <minSeverity>0.01</minSeverity>
        <capMods>
          <li>
            <capacity>Sight</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
        <statOffsets>
          <ShootingAccuracyPawn>-0.05</ShootingAccuracyPawn>
          <AimingDelayFactor>0.08</AimingDelayFactor>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.55</minSeverity>
        <capMods>
          <li>
            <capacity>Sight</capacity>
            <offset>-0.18</offset>
          </li>
        </capMods>
        <statOffsets>
          <ShootingAccuracyPawn>-0.09</ShootingAccuracyPawn>
          <AimingDelayFactor>0.14</AimingDelayFactor>
          <MoveSpeed>-0.04</MoveSpeed>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
