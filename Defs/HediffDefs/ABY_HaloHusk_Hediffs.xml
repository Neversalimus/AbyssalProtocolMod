<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef>
    <defName>ABY_HaloJudgmentMarked</defName>
    <label>halo judgment</label>
    <description>A hostile halo-mark burns across the target's silhouette. Movement becomes less certain and evasive motion degrades under the weight of the mark.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <scenarioCanAdd>false</scenarioCanAdd>
    <tendable>false</tendable>
    <stages>
      <li>
        <statOffsets>
          <MoveSpeed>-0.50</MoveSpeed>
          <MeleeDodgeChance>-0.06</MeleeDodgeChance>
        </statOffsets>
      </li>
    </stages>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>600</disappearsAfterTicks>
      </li>
      <li Class="AbyssalProtocol.HediffCompProperties_ABY_HaloJudgmentMark">
        <visualPulseIntervalTicks>45</visualPulseIntervalTicks>
        <visualScale>0.95</visualScale>
      </li>
    </comps>
  </HediffDef>

</Defs>
