<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>ABY_AbyssalAttunement</defName>
    <label>abyssal attunement</label>
    <description>A low infernal resonance leaking from an active Abyssal Forge. It sharpens industrial focus and makes the colony more comfortable around forbidden machinery as the forge consumes greater amounts of residue.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>false</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(1.0, 0.48, 0.22)</defaultLabelColor>
    <stages>
      <li>
        <label>faint attunement</label>
        <minSeverity>0.1</minSeverity>
        <statOffsets>
          <WorkSpeedGlobal>0.03</WorkSpeedGlobal>
          <ResearchSpeed>0.04</ResearchSpeed>
          <PsychicSensitivity>0.02</PsychicSensitivity>
        </statOffsets>
      </li>
      <li>
        <label>stable attunement</label>
        <minSeverity>2</minSeverity>
        <statOffsets>
          <WorkSpeedGlobal>0.05</WorkSpeedGlobal>
          <ResearchSpeed>0.07</ResearchSpeed>
          <PsychicSensitivity>0.04</PsychicSensitivity>
        </statOffsets>
      </li>
      <li>
        <label>deep attunement</label>
        <minSeverity>3</minSeverity>
        <statOffsets>
          <WorkSpeedGlobal>0.07</WorkSpeedGlobal>
          <ResearchSpeed>0.10</ResearchSpeed>
          <PsychicSensitivity>0.06</PsychicSensitivity>
        </statOffsets>
      </li>
      <li>
        <label>crowned attunement</label>
        <minSeverity>4</minSeverity>
        <statOffsets>
          <WorkSpeedGlobal>0.09</WorkSpeedGlobal>
          <ResearchSpeed>0.14</ResearchSpeed>
          <PsychicSensitivity>0.08</PsychicSensitivity>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
