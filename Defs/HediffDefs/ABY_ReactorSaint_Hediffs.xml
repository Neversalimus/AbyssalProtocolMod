<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>ABY_ReactorSaturation</defName>
    <label>reactor saturation</label>
    <description>Superheated infernal reactor wash is clinging to armor seams, optics, and exposed tissue. Movement slows, targeting degrades, and thermal protection begins to fail under the Saint's field pressure.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(1.00, 0.34, 0.12)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>180</disappearsAfterTicks>
      </li>
    </comps>
    <stages>
      <li>
        <minSeverity>0.01</minSeverity>
        <statOffsets>
          <MoveSpeed>-0.05</MoveSpeed>
          <ShootingAccuracyPawn>-0.04</ShootingAccuracyPawn>
          <AimingDelayFactor>0.06</AimingDelayFactor>
          <ArmorRating_Heat>-0.10</ArmorRating_Heat>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.45</minSeverity>
        <statOffsets>
          <MoveSpeed>-0.10</MoveSpeed>
          <ShootingAccuracyPawn>-0.08</ShootingAccuracyPawn>
          <AimingDelayFactor>0.12</AimingDelayFactor>
          <ArmorRating_Heat>-0.20</ArmorRating_Heat>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.85</minSeverity>
        <statOffsets>
          <MoveSpeed>-0.16</MoveSpeed>
          <ShootingAccuracyPawn>-0.12</ShootingAccuracyPawn>
          <AimingDelayFactor>0.18</AimingDelayFactor>
          <ArmorRating_Heat>-0.35</ArmorRating_Heat>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
