<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <HediffDef>
    <defName>ABY_HexMark</defName>
    <label>hex mark</label>
    <description>A techno-infernal target mark bleeds tracking noise through muscles and sightlines, slowing movement and making the victim easier for the next abyssal burst to finish.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <isBad>true</isBad>
    <tendable>false</tendable>
    <scenarioCanAdd>false</scenarioCanAdd>
    <defaultLabelColor>(0.95, 0.42, 0.12)</defaultLabelColor>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>300</disappearsAfterTicks>
      </li>
    </comps>
    <stages>
      <li>
        <minSeverity>0.01</minSeverity>
        <statOffsets>
          <MoveSpeed>-0.18</MoveSpeed>
          <ShootingAccuracyPawn>-0.05</ShootingAccuracyPawn>
          <ArmorRating_Sharp>-0.06</ArmorRating_Sharp>
        </statOffsets>
      </li>
      <li>
        <minSeverity>0.55</minSeverity>
        <statOffsets>
          <MoveSpeed>-0.28</MoveSpeed>
          <ShootingAccuracyPawn>-0.08</ShootingAccuracyPawn>
          <ArmorRating_Sharp>-0.10</ArmorRating_Sharp>
        </statOffsets>
      </li>
    </stages>
  </HediffDef>

</Defs>
