<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <PawnKindDef ParentName="AnimalKindBase">
    <defName>ABY_ArchonBeast</defName>
    <label>archon beast</label>
    <race>ABY_ArchonBeast</race>
    <defaultFactionType>ABY_AbyssalHost</defaultFactionType>
    <combatPower>900</combatPower>
    <ecoSystemWeight>0</ecoSystemWeight>
    <canArriveManhunter>false</canArriveManhunter>

    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalDifficultyScaling">
        <contentTier>4</contentTier>
        <difficultyFloorDefName>ABY_Difficulty_Severe</difficultyFloorDefName>
        <role>boss</role>
        <budgetCost>900</budgetCost>
        <selectionWeight>1.00</selectionWeight>
        <maxPlanCount>1</maxPlanCount>
        <allowFutureAutoEscalation>true</allowFutureAutoEscalation>
        <encounterPools>
          <li>boss_main</li>
        </encounterPools>
      </li>
    </modExtensions>

    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Pawn/ArchonBeast/ArchonBeast</texPath>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>(7.2,7.2)</drawSize>
          <shadowData>
            <volume>(3.9, 1.15, 2.15)</volume>
            <offset>(0, 0, -0.35)</offset>
          </shadowData>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

  <PawnKindDef ParentName="AnimalKindBase">
    <defName>ABY_ArchonOfRupture</defName>
    <label>archon of rupture</label>
    <race>ABY_ArchonOfRupture</race>
    <defaultFactionType>ABY_AbyssalHost</defaultFactionType>
    <combatPower>9000</combatPower>
    <ecoSystemWeight>0</ecoSystemWeight>
    <canArriveManhunter>false</canArriveManhunter>

    <modExtensions>
      <li Class="AbyssalProtocol.DefModExtension_AbyssalDifficultyScaling">
        <contentTier>6</contentTier>
        <difficultyFloorDefName>ABY_Difficulty_FinalGate</difficultyFloorDefName>
        <role>boss</role>
        <budgetCost>9000</budgetCost>
        <selectionWeight>1.00</selectionWeight>
        <maxPlanCount>1</maxPlanCount>
        <allowFutureAutoEscalation>true</allowFutureAutoEscalation>
        <encounterPools>
          <li>boss_main</li>
        </encounterPools>
      </li>
    </modExtensions>

    <lifeStages>
      <li>
        <bodyGraphicData>
          <texPath>Pawn/ArchonOfRupture/ArchonOfRupture</texPath>
          <graphicClass>Graphic_Multi</graphicClass>
          <drawSize>(10.2,10.2)</drawSize>
          <shadowData>
            <volume>(5.8, 1.45, 3.0)</volume>
            <offset>(0, 0, -0.50)</offset>
          </shadowData>
        </bodyGraphicData>
      </li>
    </lifeStages>
  </PawnKindDef>

</Defs>
