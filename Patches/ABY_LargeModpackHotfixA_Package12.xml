<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <!--
    Package 14B XML hygiene fix.
    The previous version did Replace + Add. When factionIconPath already existed,
    the Add operation targeted no nodes and RimWorld logged a patch failure.
    This conditional keeps the icon path stable without producing a failed Add.
  -->
  <Operation Class="PatchOperationConditional">
    <xpath>/Defs/FactionDef[defName="ABY_AbyssalHost"]/factionIconPath</xpath>
    <match Class="PatchOperationReplace">
      <xpath>/Defs/FactionDef[defName="ABY_AbyssalHost"]/factionIconPath</xpath>
      <value>
        <factionIconPath>UI/Icons/ABY_FactionIcon</factionIconPath>
      </value>
    </match>
    <nomatch Class="PatchOperationAdd">
      <xpath>/Defs/FactionDef[defName="ABY_AbyssalHost"]</xpath>
      <value>
        <factionIconPath>UI/Icons/ABY_FactionIcon</factionIconPath>
      </value>
    </nomatch>
  </Operation>

</Patch>
