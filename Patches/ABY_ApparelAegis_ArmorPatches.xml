<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <success>Always</success>
    <operations>
      <!-- Saint Aegis Carapace: use the working apparel-level interception path. -->
      <li Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[defName="ABY_SaintAegisCarapace"]/thingClass</xpath>
        <value>
          <thingClass>AbyssalProtocol.Apparel_ABY_ArmorAegis</thingClass>
        </value>
      </li>

      <!-- Saint Aegis Carapace: larger shield, slower recharge. -->
      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_SaintAegisCarapace" and not(modExtensions)]</xpath>
        <value>
          <modExtensions />
        </value>
      </li>

      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_SaintAegisCarapace"]/modExtensions[not(li[@Class="AbyssalProtocol.DefModExtension_ABY_ApparelAegis"])]</xpath>
        <value>
          <li Class="AbyssalProtocol.DefModExtension_ABY_ApparelAegis">
            <labelKey>ABY_ApparelAegis_SaintLabel</labelKey>
            <gizmoSubtitleKey>ABY_ApparelAegis_SaintGizmoSubtitle</gizmoSubtitleKey>
            <gizmoTheme>Saint</gizmoTheme>
            <maxShieldPoints>240</maxShieldPoints>
            <rechargeDelayTicks>600</rechargeDelayTicks>
            <rechargeIntervalTicks>30</rechargeIntervalTicks>
            <rechargePerInterval>1.2</rechargePerInterval>
            <absorbRanged>true</absorbRanged>
            <absorbExplosive>true</absorbExplosive>
            <absorbMelee>false</absorbMelee>
            <empDrainsShield>true</empDrainsShield>
            <empDrainMultiplier>2.4</empDrainMultiplier>
            <suppressWhenExternalShieldWorn>true</suppressWhenExternalShieldWorn>
            <hitFlashScale>0.85</hitFlashScale>
            <breakFlashScale>1.65</breakFlashScale>
            <restoreFlashScale>1.10</restoreFlashScale>
            <breakSoundDefName>ABY_ReactorSaintImpact</breakSoundDefName>
            <restoreSoundDefName>ABY_ReactorSaintCharge</restoreSoundDefName>
          </li>
        </value>
      </li>

      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_SaintAegisCarapace" and not(comps)]</xpath>
        <value>
          <comps />
        </value>
      </li>

      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_SaintAegisCarapace"]/comps[not(li[@Class="AbyssalProtocol.CompProperties_ABY_ApparelAegisInfo"])]</xpath>
        <value>
          <li Class="AbyssalProtocol.CompProperties_ABY_ApparelAegisInfo" />
        </value>
      </li>

      <!-- Crowned Core Plate: use the working apparel-level interception path. -->
      <li Class="PatchOperationReplace">
        <xpath>/Defs/ThingDef[defName="ABY_CrownedCorePlate"]/thingClass</xpath>
        <value>
          <thingClass>AbyssalProtocol.Apparel_ABY_ArmorAegis</thingClass>
        </value>
      </li>

      <!-- Crowned Core Plate: smaller shield, much faster recovery. -->
      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_CrownedCorePlate" and not(modExtensions)]</xpath>
        <value>
          <modExtensions />
        </value>
      </li>

      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_CrownedCorePlate"]/modExtensions[not(li[@Class="AbyssalProtocol.DefModExtension_ABY_ApparelAegis"])]</xpath>
        <value>
          <li Class="AbyssalProtocol.DefModExtension_ABY_ApparelAegis">
            <labelKey>ABY_ApparelAegis_CrownLabel</labelKey>
            <gizmoSubtitleKey>ABY_ApparelAegis_CrownGizmoSubtitle</gizmoSubtitleKey>
            <gizmoTheme>Crown</gizmoTheme>
            <maxShieldPoints>130</maxShieldPoints>
            <rechargeDelayTicks>180</rechargeDelayTicks>
            <rechargeIntervalTicks>30</rechargeIntervalTicks>
            <rechargePerInterval>5.0</rechargePerInterval>
            <absorbRanged>true</absorbRanged>
            <absorbExplosive>true</absorbExplosive>
            <absorbMelee>false</absorbMelee>
            <empDrainsShield>true</empDrainsShield>
            <empDrainMultiplier>2.4</empDrainMultiplier>
            <suppressWhenExternalShieldWorn>true</suppressWhenExternalShieldWorn>
            <hitFlashScale>0.72</hitFlashScale>
            <breakFlashScale>1.30</breakFlashScale>
            <restoreFlashScale>1.30</restoreFlashScale>
            <breakSoundDefName>ABY_ReactorSaintImpact</breakSoundDefName>
            <restoreSoundDefName>ABY_ReactorSaintCharge</restoreSoundDefName>
          </li>
        </value>
      </li>

      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_CrownedCorePlate" and not(comps)]</xpath>
        <value>
          <comps />
        </value>
      </li>

      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_CrownedCorePlate"]/comps[not(li[@Class="AbyssalProtocol.CompProperties_ABY_ApparelAegisInfo"])]</xpath>
        <value>
          <li Class="AbyssalProtocol.CompProperties_ABY_ApparelAegisInfo" />
        </value>
      </li>
    </operations>
  </Operation>
</Patch>
