<?xml version="1.0" encoding="utf-8" ?>
<Patch>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="ABY_RiftCarbine"]/description</xpath>
    <value>
      <description>Refitted as a triple-barrel infernal beam weapon, the Rift Carbine now spits chained breach lances that soften armor plating before rupturing it in a molten flare.</description>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="ABY_RiftCarbine"]/verbs/li/defaultProjectile</xpath>
    <value>
      <defaultProjectile>ABY_RiftCarbineBeamBurst</defaultProjectile>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="ABY_RiftCarbine"]/verbs/li/warmupTime</xpath>
    <value>
      <warmupTime>1.10</warmupTime>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="ABY_RiftCarbine"]/verbs/li/range</xpath>
    <value>
      <range>28.9</range>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="ABY_RiftCarbine"]/verbs/li/ticksBetweenBurstShots</xpath>
    <value>
      <ticksBetweenBurstShots>9</ticksBetweenBurstShots>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="ABY_RiftCarbine"]/verbs/li/burstShotCount</xpath>
    <value>
      <burstShotCount>3</burstShotCount>
    </value>
  </Operation>

  <Operation Class="PatchOperationReplace">
    <xpath>/Defs/ThingDef[defName="ABY_RiftCarbine"]/verbs/li/soundCast</xpath>
    <value>
      <soundCast>ABY_RiftCarbineFire</soundCast>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/ThingDef[defName="ABY_RiftCarbine"]/verbs/li</xpath>
    <value>
      <soundAiming>ABY_RiftCarbineCharge</soundAiming>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>/Defs/ThingDef[defName="ABY_RiftCarbine"]/verbs/li</xpath>
    <value>
      <soundCastTail>ABY_RiftCarbineTail</soundCastTail>
    </value>
  </Operation>

</Patch>
