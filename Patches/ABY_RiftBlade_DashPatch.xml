<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_RiftBlade" and not(modExtensions)]</xpath>
        <value>
          <modExtensions />
        </value>
      </li>

      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_RiftBlade"]/modExtensions[not(li[@Class="AbyssalProtocol.RiftDashWeaponExtension"])]</xpath>
        <value>
          <li Class="AbyssalProtocol.RiftDashWeaponExtension">
            <maxRange>10</maxRange>
            <cooldownTicks>240</cooldownTicks>
            <entryMoteDef>ABY_Mote_RiftBladeDashEntry</entryMoteDef>
            <exitMoteDef>ABY_Mote_RiftBladeDashExit</exitMoteDef>
            <trailMoteDef>ABY_Mote_RiftBladeDashTrail</trailMoteDef>
            <sparkMoteDef>ABY_Mote_RiftBladeDashSpark</sparkMoteDef>
            <shardMoteDef>ABY_Mote_RiftBladeDashShard</shardMoteDef>
            <soundDef>ABY_RiftBladeDash</soundDef>
            <entryMoteScale>0.84</entryMoteScale>
            <exitMoteScale>0.96</exitMoteScale>
            <trailMoteScale>0.68</trailMoteScale>
            <sparkMoteScale>0.46</sparkMoteScale>
            <shardMoteScale>0.54</shardMoteScale>
            <trailSteps>4</trailSteps>
            <trailParticleBurst>2</trailParticleBurst>
            <endpointParticleBurst>5</endpointParticleBurst>
            <particleJitter>0.18</particleJitter>
            <requireLineOfSight>true</requireLineOfSight>
          </li>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>
