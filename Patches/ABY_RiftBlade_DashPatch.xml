<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <operations>
      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_RiftBlade"]</xpath>
        <value>
          <modExtensions />
        </value>
      </li>

      <li Class="PatchOperationAdd">
        <xpath>/Defs/ThingDef[defName="ABY_RiftBlade"]/modExtensions</xpath>
        <value>
          <li Class="AbyssalProtocol.RiftDashWeaponExtension">
            <maxRange>10</maxRange>
            <cooldownTicks>240</cooldownTicks>
            <entryMoteDef>ABY_Mote_ArchonDashEntry</entryMoteDef>
            <exitMoteDef>ABY_Mote_ArchonDashExit</exitMoteDef>
            <trailMoteDef>ABY_Mote_ArchonDashTrail</trailMoteDef>
            <entryMoteScale>0.95</entryMoteScale>
            <exitMoteScale>1.10</exitMoteScale>
            <trailMoteScale>0.75</trailMoteScale>
            <trailSteps>5</trailSteps>
            <requireLineOfSight>true</requireLineOfSight>
          </li>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>
