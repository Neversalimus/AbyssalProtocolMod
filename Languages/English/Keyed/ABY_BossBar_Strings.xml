<?xml version="1.0" encoding="utf-8"?>
<LanguageData>
  <ABY_ModSettingsCategory>Abyssal Protocol</ABY_ModSettingsCategory>
  <ABY_BossBar_Enable>Enable abyssal boss bars</ABY_BossBar_Enable>
  <ABY_BossBar_EnableDesc>Shows the custom Abyssal Protocol boss HUD for supported active bosses.</ABY_BossBar_EnableDesc>
  <ABY_BossBar_ShowHealthNumbers>Show health numbers</ABY_BossBar_ShowHealthNumbers>
  <ABY_BossBar_ShowHealthNumbersDesc>Displays current and maximum health values on the boss bar.</ABY_BossBar_ShowHealthNumbersDesc>
  <ABY_BossBar_ShowPhaseMarkers>Show phase markers</ABY_BossBar_ShowPhaseMarkers>
  <ABY_BossBar_ShowPhaseMarkersDesc>Displays threshold markers for supported boss phase transitions.</ABY_BossBar_ShowPhaseMarkersDesc>
  <ABY_BossBar_ShowPhaseLabel>Show current phase label</ABY_BossBar_ShowPhaseLabel>
  <ABY_BossBar_ShowPhaseLabelDesc>Displays the current phase tag under the boss bar.</ABY_BossBar_ShowPhaseLabelDesc>
  <ABY_BossBar_ShowSecondaryBars>Show secondary bars</ABY_BossBar_ShowSecondaryBars>
  <ABY_BossBar_ShowSecondaryBarsDesc>Displays supported secondary boss resources such as the Reactor Saint's Aegis.</ABY_BossBar_ShowSecondaryBarsDesc>
  <ABY_BossBar_ShowCalibrationButton>Show adjustment button on boss bar</ABY_BossBar_ShowCalibrationButton>
  <ABY_BossBar_ShowCalibrationButtonDesc>Adds a small live-adjust button next to the active boss bar.</ABY_BossBar_ShowCalibrationButtonDesc>
  <ABY_BossBar_ReducedMotion>Reduced motion</ABY_BossBar_ReducedMotion>
  <ABY_BossBar_ReducedMotionDesc>Softens sheen, pulsing, and catch-up animation on the boss bar.</ABY_BossBar_ReducedMotionDesc>
  <ABY_BossBar_Anchor>Anchor preset</ABY_BossBar_Anchor>
